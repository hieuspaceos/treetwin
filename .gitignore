# dependencies
node_modules/
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# testing
/coverage

# astro
.astro/
dist/

# next.js (legacy)
/.next/
/out/
bin/
!packages/*/bin/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# package manager
package-lock.json
yarn.lock
pnpm-lock.yaml

# semantic-release
.nyc_output

# env files (can opt-in for committing if needed)
.env*
!.env.example

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts
src/payload-types.ts

# flutter
.dart_tool
build
GoogleService-Info.plist

repomix-output.*
repomix-snapshot.*
.serena/cache
plans/**/*
!plans/templates/*
screenshots/*
docs/screenshots/*
logs.txt
logs/distribution-log.csv
test-ck
__pycache__

# CK meta commands
prompt.md
ck.md

# ClaudeKit tooling (not project code)
.claude/

# MCP config (contains credentials)
.mcp.json

# Gemini CLI settings (symlink to .claude/.mcp.json)
.gemini/settings.json
.claude/settings.bak.json
# External repos for study/reference
external/

# OpenCode
.opencode/

# Git worktrees (local development only)
worktrees/

# Release manifest
release-manifest.json

# Local SQLite fallback (generated at runtime)
data/
