# ========================================
# TreeID Environment Variables
# ========================================
# Copy this file to .env.local and fill in your values:
#   cp .env.example .env.local

# === REQUIRED ===
# Your deployed URL (e.g. https://my-site.vercel.app)
PUBLIC_SITE_URL=http://localhost:4321

# === OPTIONAL: Cloudflare R2 (video manifests, media storage) ===
# Only needed if you enable videoFactory in src/config/site-config.ts
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Format: ACCOUNT_ID.r2.cloudflarestorage.com (no https://)
R2_ENDPOINT=
R2_BUCKET=
R2_REGION=auto
# Public URL for serving media (custom domain or R2 public URL)
R2_PUBLIC_URL=

# === OPTIONAL: Admin Dashboard ===
# Password for admin login (plain text — set a strong password)
ADMIN_PASSWORD=
# Secret key for signing JWT session tokens (any random string, min 32 chars)
ADMIN_SECRET=
# GitHub personal access token with repo write access (for production content writes)
# Only needed when deployed — local dev uses filesystem directly
GITHUB_TOKEN=

# === OPTIONAL: Multi-User Auth ===
# JSON array of users. If not set, falls back to single ADMIN_PASSWORD mode.
# ADMIN_USERS='[{"username":"admin","password":"xxx","role":"admin"},{"username":"editor","password":"yyy","role":"editor"}]'

# === OPTIONAL: Email Newsletter (Resend) ===
# Get API key from https://resend.com — free tier: 3000 emails/month
RESEND_API_KEY=
# Verified sender email (must match your Resend domain)
RESEND_FROM_EMAIL=noreply@example.com

# === OPTIONAL: Google Analytics 4 ===
# GA4 Measurement ID (format: G-XXXXXXXXXX)
GA_MEASUREMENT_ID=

# === OPTIONAL: GoClaw Integration ===
# All /api/goclaw/* endpoints return 503 if GOCLAW_API_KEY is not set
GOCLAW_API_KEY=
GOCLAW_WEBHOOK_SECRET=

# === OPTIONAL: Better Auth (SaaS user Google OAuth) ===
# Random 32+ char secret for signing sessions
BETTER_AUTH_SECRET=
# Google OAuth credentials from console.cloud.google.com
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# === OPTIONAL: Turso Database (SaaS user landing pages) ===
# Create DB: turso db create tree-id
# Get token: turso db tokens create tree-id
TURSO_URL=libsql://your-db-name-your-org.turso.io
TURSO_AUTH_TOKEN=

# === OPTIONAL: Supabase (Marketplace) ===
# Create project at https://supabase.com — free tier supports marketplace scale
PUBLIC_SUPABASE_URL=https://your-project.supabase.co
PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Firecrawl (AI Clone — JS rendering for SPA sites, optional)
# Get free API key at https://firecrawl.dev (500 pages free)
FIRECRAWL_API_KEY=your-firecrawl-api-key
