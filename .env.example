# Database (Supabase PostgreSQL)
# Direct connection (local dev) — port 5432
# DATABASE_URL=postgresql://postgres:PASSWORD@db.REGION.supabase.co:5432/postgres
# Pooler connection (Vercel serverless) — port 6543
DATABASE_URL=postgresql://postgres:PASSWORD@db.REGION.supabase.co:6543/postgres?sslmode=require

# Cloudflare R2 Storage
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
# Format: ACCOUNT_ID.r2.cloudflarestorage.com (no https://)
R2_ENDPOINT=ACCOUNT_ID.r2.cloudflarestorage.com
R2_BUCKET=tree-id-media
R2_REGION=auto
# Public URL for serving media (custom domain or R2 public URL)
R2_PUBLIC_URL=https://cdn.yourdomain.com

# App
NEXT_PUBLIC_SITE_URL=http://localhost:3000
# Min 32 chars — generate with: openssl rand -base64 32
PAYLOAD_SECRET=your-secret-key-minimum-32-characters-long
