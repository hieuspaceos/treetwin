---
import type { GalleryData } from '@/lib/landing/landing-types'

interface Props extends GalleryData {}
const { heading, images = [] } = Astro.props
---

<section class="landing-section">
  {heading && <h2 class="mb-8 text-center text-3xl font-bold text-slate-900">{heading}</h2>}
  <div class="grid grid-cols-2 gap-4 md:grid-cols-3 lg:grid-cols-4">
    {images.map((img) => (
      <div class="overflow-hidden rounded-xl">
        <img src={img.src} alt={img.alt || ''} class="w-full object-cover aspect-square hover:scale-105 transition-transform duration-300" loading="lazy" />
        {img.caption && <p class="mt-1 text-center text-xs text-slate-500">{img.caption}</p>}
      </div>
    ))}
  </div>
</section>
