---
/**
 * Gallery section with 5 layout variants:
 * - grid: responsive grid (default), configurable columns
 * - masonry: CSS columns for mixed-height images
 * - carousel: horizontal scroll with snap
 * - lightbox: grid with click-to-enlarge overlay
 * - filmstrip: single-row horizontal strip with peek
 */
import type { GalleryData } from '@/lib/landing/landing-types'

interface Props extends GalleryData {}
const { heading, subheading, images = [], variant = 'grid', columns = 4 } = Astro.props
const gridClass = `landing-grid-${Math.min(columns, 5)}`
---

<section class="landing-section">
  {heading && (
    <div class="lp-section-heading" style="text-align:center;margin-bottom:2rem">
      <h2>{heading}</h2>
      {subheading && <p style="color:var(--lp-text-muted);margin-top:0.5rem">{subheading}</p>}
    </div>
  )}

  {/* Grid: responsive columns */}
  {variant === 'grid' && (
    <div class={gridClass} style="gap:0.75rem">
      {images.map((img) => (
        <div class="lp-card-hover" style="overflow:hidden;border-radius:var(--lp-radius, 12px)">
          <img src={img.src} alt={img.alt || ''} style="width:100%;aspect-ratio:4/3;object-fit:cover" loading="lazy" decoding="async" />
          {img.caption && <p style="padding:0.5rem;text-align:center;font-size:0.75rem;color:var(--lp-text-muted)">{img.caption}</p>}
        </div>
      ))}
    </div>
  )}

  {/* Masonry: CSS columns for mixed heights */}
  {variant === 'masonry' && (
    <div class="lp-gallery-masonry">
      {images.map((img) => (
        <div class="lp-card-hover" style="break-inside:avoid;margin-bottom:0.75rem;overflow:hidden;border-radius:var(--lp-radius, 12px)">
          <img src={img.src} alt={img.alt || ''} style="width:100%;display:block" loading="lazy" decoding="async" />
          {img.caption && <p style="padding:0.5rem;text-align:center;font-size:0.75rem;color:var(--lp-text-muted)">{img.caption}</p>}
        </div>
      ))}
    </div>
  )}

  {/* Carousel: auto-scroll with mask, arrows, dots — same pattern as testimonials */}
  {variant === 'carousel' && (() => {
    const carouselImages = [...images, ...images] // duplicate for infinite loop
    const carouselId = `lp-gallery-carousel-${Math.random().toString(36).slice(2, 8)}`
    return (
      <div class="lp-carousel-wrapper" id={carouselId} style="overflow:hidden;padding-left:0;padding-right:0">
        <button class="lp-carousel-arrow lp-carousel-prev" aria-label="Previous" data-dir="prev">‹</button>
        <button class="lp-carousel-arrow lp-carousel-next" aria-label="Next" data-dir="next">›</button>
        <div class="lp-gallery-carousel-track-wrap">
          <div class="lp-gallery-carousel-track">
            {carouselImages.map((img, i) => (
              <div class="lp-gallery-carousel-slide lp-card-hover">
                <img src={img.src} alt={img.alt || ''} style="width:100%;height:100%;object-fit:cover" loading="lazy" decoding="async" />
                {img.caption && <p style="position:absolute;bottom:0;left:0;right:0;padding:0.5rem;background:linear-gradient(transparent,rgba(0,0,0,0.6));color:#fff;font-size:0.75rem;margin:0">{img.caption}</p>}
              </div>
            ))}
          </div>
        </div>
        <div class="lp-carousel-dots">
          {Array.from({ length: Math.min(6, images.length) }, (_, i) => (
            <button class={`lp-carousel-dot${i === 0 ? ' active' : ''}`} data-index={i} aria-label={`Group ${i + 1}`} />
          ))}
        </div>
      </div>
    )
  })()}

  {/* Lightbox: grid + click to enlarge */}
  {variant === 'lightbox' && (
    <>
      <div class={gridClass} style="gap:0.75rem">
        {images.map((img, i) => (
          <div class="lp-card-hover lp-gallery-lightbox-thumb" data-lightbox-idx={i} style="overflow:hidden;border-radius:var(--lp-radius, 12px);cursor:zoom-in">
            <img src={img.src} alt={img.alt || ''} style="width:100%;aspect-ratio:4/3;object-fit:cover" loading="lazy" decoding="async" />
          </div>
        ))}
      </div>
      <div class="lp-gallery-lightbox-overlay" id="lp-gallery-lightbox" style="display:none">
        <button class="lp-gallery-lightbox-close" aria-label="Close">×</button>
        <img class="lp-gallery-lightbox-img" src="" alt="" />
        <p class="lp-gallery-lightbox-caption"></p>
      </div>
      <script define:vars={{ images }}>
        document.addEventListener('DOMContentLoaded', () => {
          const overlay = document.getElementById('lp-gallery-lightbox')
          if (!overlay) return
          const img = overlay.querySelector('.lp-gallery-lightbox-img')
          const caption = overlay.querySelector('.lp-gallery-lightbox-caption')
          document.querySelectorAll('.lp-gallery-lightbox-thumb').forEach(thumb => {
            thumb.addEventListener('click', () => {
              const idx = Number(thumb.getAttribute('data-lightbox-idx'))
              const item = images[idx]
              if (!item || !img) return
              img.src = item.src
              img.alt = item.alt || ''
              if (caption) caption.textContent = item.caption || ''
              overlay.style.display = 'flex'
              document.body.style.overflow = 'hidden'
            })
          })
          overlay.querySelector('.lp-gallery-lightbox-close')?.addEventListener('click', () => {
            overlay.style.display = 'none'
            document.body.style.overflow = ''
          })
          overlay.addEventListener('click', (e) => { if (e.target === overlay) { overlay.style.display = 'none'; document.body.style.overflow = '' } })
        })
      </script>
    </>
  )}

  {/* Filmstrip: single-row horizontal strip */}
  {variant === 'filmstrip' && (
    <div class="lp-gallery-filmstrip">
      {images.map((img) => (
        <div style="flex-shrink:0;width:280px;height:200px;position:relative;border-radius:var(--lp-radius, 12px);overflow:hidden" class="lp-card-hover">
          <img src={img.src} alt={img.alt || ''} style="width:100%;height:100%;object-fit:cover" loading="lazy" decoding="async" />
          {img.caption && <p style="position:absolute;bottom:0;left:0;right:0;padding:0.4rem 0.6rem;background:linear-gradient(transparent,rgba(0,0,0,0.5));color:#fff;font-size:0.7rem">{img.caption}</p>}
        </div>
      ))}
    </div>
  )}
</section>

<style>
  /* Masonry */
  .lp-gallery-masonry { columns: 2; column-gap: 0.75rem; }
  @media (min-width: 640px) { .lp-gallery-masonry { columns: 3; } }
  @media (min-width: 1024px) { .lp-gallery-masonry { columns: 4; } }

  /* Carousel — reuses lp-carousel-wrapper/arrow/dot from testimonials CSS */
  .lp-gallery-carousel-track-wrap {
    width: 100%; overflow: hidden;
    mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
    -webkit-mask-image: linear-gradient(to right, transparent, black 5%, black 95%, transparent);
  }
  .lp-gallery-carousel-track {
    display: flex; gap: 1rem; width: max-content;
    animation: lp-gallery-scroll 25s linear infinite;
  }
  .lp-gallery-carousel-track:hover { animation-play-state: paused; }
  .lp-gallery-carousel-slide {
    flex-shrink: 0; width: 320px; height: 240px; position: relative;
    border-radius: var(--lp-radius, 12px); overflow: hidden;
  }
  @media (min-width: 640px) { .lp-gallery-carousel-slide { width: 400px; height: 300px; } }
  @media (max-width: 640px) { .lp-gallery-carousel-slide { width: 280px; height: 200px; } }
  @keyframes lp-gallery-scroll {
    0% { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* Lightbox overlay */
  .lp-gallery-lightbox-overlay {
    position: fixed; inset: 0; z-index: 9999; background: rgba(0,0,0,0.9);
    display: flex; align-items: center; justify-content: center; flex-direction: column;
  }
  .lp-gallery-lightbox-close {
    position: absolute; top: 1rem; right: 1.5rem; background: none; border: none;
    color: #fff; font-size: 2rem; cursor: pointer; z-index: 1;
  }
  .lp-gallery-lightbox-img { max-width: 90vw; max-height: 80vh; object-fit: contain; border-radius: 8px; }
  .lp-gallery-lightbox-caption { color: rgba(255,255,255,0.8); font-size: 0.85rem; margin-top: 0.75rem; }

  /* Filmstrip */
  .lp-gallery-filmstrip {
    display: flex; gap: 0.75rem; overflow-x: auto; scroll-snap-type: x mandatory;
    scrollbar-width: thin; padding-bottom: 0.5rem;
  }
</style>

<!-- Gallery carousel JS uses same pattern as testimonials carousel -->
<script>
  document.addEventListener('DOMContentLoaded', () => {
    document.querySelectorAll('.lp-gallery-carousel-track-wrap').forEach(wrap => {
      const wrapper = wrap.closest('.lp-carousel-wrapper')
      if (!wrapper) return
      const track = wrap.querySelector('.lp-gallery-carousel-track') as HTMLElement
      const dots = wrapper.querySelectorAll('.lp-carousel-dot')
      if (!track) return

      const slideWidth = 320 + 16

      function scrollBy(offset: number) {
        track.style.animation = 'none'
        const current = -new DOMMatrix(getComputedStyle(track).transform).m41
        track.style.transform = `translateX(${-(current + offset)}px)`
        clearTimeout((track as any)._resume)
        ;(track as any)._resume = setTimeout(() => {
          track.style.transform = ''
          track.style.animation = ''
        }, 4000)
      }

      wrapper.querySelector('.lp-carousel-prev')?.addEventListener('click', () => scrollBy(-slideWidth))
      wrapper.querySelector('.lp-carousel-next')?.addEventListener('click', () => scrollBy(slideWidth))

      const dotCount = dots.length
      const totalSlides = track.children.length / 2
      const slidesPerDot = Math.ceil(totalSlides / dotCount)
      dots.forEach((dot, i) => {
        dot.addEventListener('click', () => {
          const current = -new DOMMatrix(getComputedStyle(track).transform).m41
          scrollBy(i * slidesPerDot * slideWidth - current)
        })
      })
    })
  })
</script>
