---
/**
 * Team section with 3 layout variants:
 * - grid (default): photo grid cards
 * - list: horizontal list with small photos
 * - compact: names/roles only, no photos
 */
import type { TeamData } from '@/lib/landing/landing-types'

interface Props extends TeamData {}
const { heading, subheading, members = [], variant = 'grid' } = Astro.props
---

{/* Grid: default photo grid */}
{variant === 'grid' && (
  <section class="landing-section">
    {heading && <h2 class="mb-2 text-center text-3xl font-bold">{heading}</h2>}
    {subheading && <p class="mx-auto mb-8 max-w-2xl text-center" style="color: var(--lp-text-muted)">{subheading}</p>}
    <div class="landing-grid-3">
      {members.map((m) => (
        <div class="glass-card p-6 text-center">
          {m.photo && <img src={m.photo} alt={m.name} class="mx-auto mb-4 h-20 w-20 rounded-full object-cover" />}
          <h3 class="text-lg font-semibold">{m.name}</h3>
          <p class="text-sm" style="color: var(--lp-text-muted)">{m.role}</p>
          {m.bio && <p class="mt-2 text-sm" style="color: var(--lp-text-muted)">{m.bio}</p>}
          {m.social && (
            <div class="mt-3 flex justify-center gap-3 text-xs" style="color: var(--lp-text-muted)">
              {m.social.twitter && <a href={m.social.twitter} target="_blank" rel="noopener noreferrer">Twitter</a>}
              {m.social.linkedin && <a href={m.social.linkedin} target="_blank" rel="noopener noreferrer">LinkedIn</a>}
              {m.social.github && <a href={m.social.github} target="_blank" rel="noopener noreferrer">GitHub</a>}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>
)}

{/* List: horizontal rows with small photos */}
{variant === 'list' && (
  <section class="landing-section">
    {heading && <h2 class="mb-2 text-center text-3xl font-bold">{heading}</h2>}
    {subheading && <p class="mx-auto mb-8 max-w-2xl text-center" style="color: var(--lp-text-muted)">{subheading}</p>}
    <div style="max-width: 720px; margin: 0 auto; display: flex; flex-direction: column; gap: 0.75rem">
      {members.map((m) => (
        <div style="display: flex; align-items: center; gap: 1.25rem; padding: 1rem 1.25rem; background: var(--lp-surface); border-radius: var(--lp-radius)">
          {m.photo
            ? <img src={m.photo} alt={m.name} style="width: 3rem; height: 3rem; border-radius: 50%; object-fit: cover; flex-shrink: 0" />
            : <div style="width: 3rem; height: 3rem; border-radius: 50%; flex-shrink: 0; background: color-mix(in srgb, var(--lp-primary) 15%, transparent); display: flex; align-items: center; justify-content: center; font-weight: 700; font-size: 1.1rem; color: var(--lp-primary)">{m.name.charAt(0)}</div>
          }
          <div style="flex: 1; min-width: 0">
            <p class="font-semibold">{m.name}</p>
            <p class="text-sm" style="color: var(--lp-text-muted)">{m.role}</p>
          </div>
          {m.bio && <p class="hidden text-sm md:block" style="color: var(--lp-text-muted); flex: 2; min-width: 0">{m.bio}</p>}
          {m.social && (
            <div class="flex gap-2 text-xs flex-shrink-0" style="color: var(--lp-text-muted)">
              {m.social.twitter && <a href={m.social.twitter} target="_blank" rel="noopener noreferrer">TW</a>}
              {m.social.linkedin && <a href={m.social.linkedin} target="_blank" rel="noopener noreferrer">LI</a>}
              {m.social.github && <a href={m.social.github} target="_blank" rel="noopener noreferrer">GH</a>}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>
)}

{/* Compact: names and roles only, no photos */}
{variant === 'compact' && (
  <section class="landing-section">
    {heading && <h2 class="mb-2 text-center text-3xl font-bold">{heading}</h2>}
    {subheading && <p class="mx-auto mb-8 max-w-2xl text-center" style="color: var(--lp-text-muted)">{subheading}</p>}
    <div style="display: flex; flex-wrap: wrap; gap: 0.75rem; justify-content: center">
      {members.map((m) => (
        <div style="padding: 0.75rem 1.25rem; background: var(--lp-surface); border-radius: var(--lp-radius); text-align: center; min-width: 140px">
          <p class="font-semibold text-sm">{m.name}</p>
          <p class="text-xs mt-0.5" style="color: var(--lp-text-muted)">{m.role}</p>
        </div>
      ))}
    </div>
  </section>
)}
