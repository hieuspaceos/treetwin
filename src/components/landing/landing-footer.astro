---
/**
 * Landing page footer section — minimal footer with optional text and links.
 */
import type { FooterData } from '@/lib/landing/landing-types'

interface Props extends FooterData {
  pageTitle?: string
}

const { text, links = [], pageTitle } = Astro.props
const year = new Date().getFullYear()
---

<footer class="landing-footer py-8 text-center text-sm">
  {links.length > 0 && (
    <div class="mb-4 flex justify-center gap-4">
      {links.map(link => (
        <a href={link.href} class="transition-colors hover:opacity-70" style="color: var(--lp-text-muted)">
          {link.label}
        </a>
      ))}
    </div>
  )}
  <p style="color: var(--lp-text-muted)">{text || `© ${year} ${pageTitle || ''}`}</p>
</footer>
