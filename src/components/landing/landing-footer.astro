---
/**
 * Landing page footer with 3 layout variants:
 * - simple (default): centered text + links
 * - columns: multi-column with link groups
 * - minimal: just copyright line
 */
import type { FooterData } from '@/lib/landing/landing-types'

interface Props extends FooterData {
  pageTitle?: string
}

const { text, links = [], columns = [], pageTitle, variant = 'simple', socialLinks = [] } = Astro.props
const year = new Date().getFullYear()
const copyright = text || `© ${year} ${pageTitle || ''}`
---

{/* Simple: centered text + links */}
{variant === 'simple' && (
  <footer class="landing-footer py-8 text-center text-sm">
    {links.length > 0 && (
      <div class="mb-4 flex justify-center gap-4">
        {links.map(link => (
          <a href={link.href} class="transition-colors hover:opacity-70" style="color: var(--lp-text-muted)">{link.label}</a>
        ))}
      </div>
    )}
    {socialLinks.length > 0 && (
      <div class="mb-3 flex justify-center gap-3">
        {socialLinks.map(sl => (
          <a href={sl.url} target="_blank" rel="noopener noreferrer" title={sl.label || sl.icon}
            class="transition-opacity hover:opacity-70" style="font-size:1.3rem;color:var(--lp-text-muted)"
            aria-label={sl.label || sl.icon}>{sl.icon}</a>
        ))}
      </div>
    )}
    <p style="color: var(--lp-text-muted)">{copyright}</p>
  </footer>
)}

{/* Columns: multi-column with link groups + brand name */}
{variant === 'columns' && (
  <footer class="landing-footer py-12 text-sm">
    <div class="mx-auto max-w-6xl px-6">
      <div class="lp-footer-grid" style={`--lp-footer-cols: ${columns.length}; margin-bottom: 2.5rem`}>
        {/* Link columns */}
        {columns.map(col => (
          <div>
            <p class="mb-3 font-semibold text-xs uppercase tracking-wider" style="color: var(--lp-text)">{col.heading}</p>
            <ul style="display: flex; flex-direction: column; gap: 0.5rem">
              {(col.links ?? []).map(link => (
                <li>
                  <a href={link.href} class="transition-colors hover:opacity-70" style="color: var(--lp-text-muted)">{link.label}</a>
                </li>
              ))}
            </ul>
          </div>
        ))}
      </div>
      <div style={`border-top: 1px solid color-mix(in srgb, var(--lp-text) 10%, transparent); padding-top: 1.5rem; display: flex; align-items: center; flex-wrap: wrap; gap: 1rem; ${(links.length > 0 || socialLinks.length > 0) ? 'justify-content: space-between' : 'justify-content: center'}`}>
        <p style="color: var(--lp-text-muted)">{copyright}</p>
        <div class="flex items-center gap-4">
          {links.map(link => (
            <a href={link.href} class="transition-colors hover:opacity-70" style="color: var(--lp-text-muted)">{link.label}</a>
          ))}
          {socialLinks.map(sl => (
            <a href={sl.url} target="_blank" rel="noopener noreferrer" title={sl.label || sl.icon}
              class="transition-opacity hover:opacity-70" style="font-size:1.2rem;color:var(--lp-text-muted)"
              aria-label={sl.label || sl.icon}>{sl.icon}</a>
          ))}
        </div>
      </div>
    </div>
  </footer>
)}

{/* Minimal: just copyright line */}
{variant === 'minimal' && (
  <footer class="landing-footer py-4 text-center text-xs" style="color: var(--lp-text-muted)">
    {socialLinks.length > 0 && (
      <div class="mb-2 flex justify-center gap-3">
        {socialLinks.map(sl => (
          <a href={sl.url} target="_blank" rel="noopener noreferrer" title={sl.label || sl.icon}
            class="transition-opacity hover:opacity-70" style="font-size:1.1rem;color:var(--lp-text-muted)"
            aria-label={sl.label || sl.icon}>{sl.icon}</a>
        ))}
      </div>
    )}
    {copyright}
  </footer>
)}
