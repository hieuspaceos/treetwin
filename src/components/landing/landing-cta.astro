---
import type { CtaData } from '@/lib/landing/landing-types'

interface Props extends CtaData {}
const { headline, subheadline, cta, variant = 'default' } = Astro.props
const variantClass = variant === 'accent' ? 'landing-cta-accent' : variant === 'dark' ? 'landing-cta-dark' : ''
---

<section class={`landing-section text-center ${variantClass}`}>
  <h2 class="text-3xl font-bold">{headline}</h2>
  {subheadline && <p class="mx-auto mt-3 max-w-xl" style="color: var(--lp-text-muted)">{subheadline}</p>}
  <a href={cta.url} class="landing-btn-primary mt-6">
    {cta.text}
  </a>
</section>
