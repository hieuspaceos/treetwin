---
/**
 * CTA section with 5 layout variants:
 * - default: centered headline + button
 * - split: text left, button right (side by side)
 * - banner: full-width gradient with large text
 * - minimal: simple text link, no button styling
 * - with-image: background image + dark overlay
 */
import type { CtaData } from '@/lib/landing/landing-types'

interface Props extends CtaData {}
const { headline, subheadline, cta, variant = 'default', backgroundImage } = Astro.props
---

{/* Default: centered */}
{variant === 'default' && (
  <section class="landing-section text-center">
    <h2 class="text-3xl font-bold">{headline}</h2>
    {subheadline && <p class="mx-auto mt-3 max-w-xl" style="color: var(--lp-text-muted)">{subheadline}</p>}
    <a href={cta.url} class="landing-btn-primary mt-6">{cta.text}</a>
  </section>
)}

{/* Split: text left, button right */}
{variant === 'split' && (
  <section class="landing-section" style="display: flex; align-items: center; justify-content: space-between; gap: 2rem; flex-wrap: wrap">
    <div style="flex: 1; min-width: 200px">
      <h2 class="text-2xl font-bold">{headline}</h2>
      {subheadline && <p class="mt-2" style="color: var(--lp-text-muted)">{subheadline}</p>}
    </div>
    <a href={cta.url} class="landing-btn-primary" style="flex-shrink: 0">{cta.text}</a>
  </section>
)}

{/* Banner: full-width gradient */}
{variant === 'banner' && (
  <section class="landing-section text-center" style={`background: linear-gradient(135deg, var(--lp-primary), var(--lp-secondary)); color: #fff; padding: 4rem 2rem; border-radius: var(--lp-radius)`}>
    <h2 class="text-4xl font-bold" style="color: #fff">{headline}</h2>
    {subheadline && <p class="mx-auto mt-3 max-w-xl" style="color: rgba(255,255,255,0.85)">{subheadline}</p>}
    <a href={cta.url} class="mt-6" style="display: inline-block; background: #fff; color: var(--lp-primary); padding: 0.75rem 2rem; border-radius: var(--lp-radius); font-weight: 700; text-decoration: none">{cta.text}</a>
  </section>
)}

{/* Minimal: text link only */}
{variant === 'minimal' && (
  <section class="landing-section text-center" style="background: transparent; padding: 2rem">
    <p class="text-lg">
      <span style="color: var(--lp-text-muted)">{headline}</span>
      {' '}
      <a href={cta.url} style="color: var(--lp-primary); font-weight: 600; text-decoration: underline">{cta.text}</a>
    </p>
  </section>
)}

{/* With Image: background image + dark overlay */}
{variant === 'with-image' && (
  <section
    class="landing-section text-center"
    style={`position: relative; background-image: url(${backgroundImage || ''}); background-size: cover; background-position: center; padding: 5rem 2rem; border-radius: var(--lp-radius); overflow: hidden`}
  >
    <div style="position: absolute; inset: 0; background: rgba(0,0,0,0.55); border-radius: inherit"></div>
    <div style="position: relative; z-index: 1">
      <h2 class="text-3xl font-bold" style="color: #fff">{headline}</h2>
      {subheadline && <p class="mx-auto mt-3 max-w-xl" style="color: rgba(255,255,255,0.8)">{subheadline}</p>}
      <a href={cta.url} class="landing-btn-primary mt-6">{cta.text}</a>
    </div>
  </section>
)}
