---
/**
 * Pricing section with 3 layout variants:
 * - cards (default): card grid layout
 * - simple: horizontal compact row
 * - highlight-center: center plan larger/elevated
 */
import type { PricingData } from '@/lib/landing/landing-types'

interface Props extends PricingData {}
const { heading, subheading, plans = [], variant = 'cards' } = Astro.props
---

{/* Cards: default grid */}
{variant === 'cards' && (
  <section class="landing-section">
    {heading && <h2 class="mb-2 text-center text-3xl font-bold">{heading}</h2>}
    {subheading && <p class="mx-auto mb-8 max-w-2xl text-center" style="color: var(--lp-text-muted)">{subheading}</p>}
    <div class={plans.length <= 2 ? 'landing-grid-2' : 'landing-grid-3'} style={plans.length <= 2 ? 'max-width: 720px; margin: 0 auto' : undefined}>
      {plans.map((plan) => (
        <div class={`p-6 flex flex-col ${plan.highlighted ? 'landing-pricing-highlight' : ''}`} style="background: var(--lp-surface); border-radius: var(--lp-radius)">
          {plan.badge && (
            <span style="display: inline-block; font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--lp-primary); padding: 0.25rem 0.75rem; background: color-mix(in srgb, var(--lp-primary) 15%, transparent); border-radius: 999px; margin-bottom: 0.75rem; width: fit-content">{plan.badge}</span>
          )}
          <h3 class="text-lg font-semibold">{plan.name}</h3>
          <div class="mt-2 flex items-baseline gap-1">
            <span class="text-3xl font-bold">{plan.price}</span>
            {plan.period && <span class="text-sm" style="color: var(--lp-text-muted)">{plan.period}</span>}
          </div>
          {plan.description && <p class="mt-2 text-sm" style="color: var(--lp-text-muted)">{plan.description}</p>}
          <ul class="mt-4 flex-1 space-y-2 text-sm">
            {(plan.features ?? []).map((f) => <li class="flex items-start gap-2"><span style="color: var(--lp-primary)">✓</span>{f}</li>)}
          </ul>
          <a
            href={plan.cta?.url}
            class={`mt-6 block px-4 py-2.5 text-center text-sm font-semibold transition-colors ${plan.highlighted ? 'landing-btn-primary' : ''}`}
            style={plan.highlighted ? undefined : `background: color-mix(in srgb, var(--lp-text) 8%, transparent); border-radius: var(--lp-radius)`}
          >{plan.cta?.text}</a>
        </div>
      ))}
    </div>
  </section>
)}

{/* Simple: horizontal compact row */}
{variant === 'simple' && (
  <section class="landing-section">
    {heading && <h2 class="mb-2 text-center text-3xl font-bold">{heading}</h2>}
    {subheading && <p class="mx-auto mb-6 max-w-2xl text-center" style="color: var(--lp-text-muted)">{subheading}</p>}
    <div style="display: flex; gap: 1rem; flex-wrap: wrap; justify-content: center">
      {plans.map((plan) => (
        <div style={`display: flex; align-items: center; gap: 1.5rem; padding: 1rem 1.5rem; background: var(--lp-surface); border-radius: var(--lp-radius); flex: 1; min-width: 200px; max-width: 360px; ${plan.highlighted ? `border: 2px solid var(--lp-primary)` : `border: 1px solid color-mix(in srgb, var(--lp-text) 10%, transparent)`}`}>
          <div style="flex: 1">
            <p class="font-semibold">{plan.name}</p>
            <p class="text-sm" style="color: var(--lp-text-muted)">{plan.price}{plan.period ? ` / ${plan.period}` : ''}</p>
          </div>
          <a
            href={plan.cta?.url}
            style={`padding: 0.4rem 1rem; border-radius: var(--lp-radius); font-size: 0.85rem; font-weight: 600; text-decoration: none; white-space: nowrap; background: ${plan.highlighted ? 'var(--lp-primary)' : 'color-mix(in srgb, var(--lp-text) 8%, transparent)'}; color: ${plan.highlighted ? '#fff' : 'var(--lp-text)'}`}
          >{plan.cta?.text}</a>
        </div>
      ))}
    </div>
  </section>
)}

{/* Highlight-center: center plan larger/elevated */}
{variant === 'highlight-center' && (
  <section class="landing-section">
    {heading && <h2 class="mb-2 text-center text-3xl font-bold">{heading}</h2>}
    {subheading && <p class="mx-auto mb-8 max-w-2xl text-center" style="color: var(--lp-text-muted)">{subheading}</p>}
    <div style="display: flex; align-items: center; gap: 1rem; flex-wrap: wrap; justify-content: center">
      {plans.map((plan, i) => {
        const isCenter = i === Math.floor(plans.length / 2) || plan.highlighted
        return (
          <div style={`display: flex; flex-direction: column; padding: ${isCenter ? '2rem' : '1.5rem'}; background: var(--lp-surface); border-radius: var(--lp-radius); flex: 1; min-width: 180px; max-width: ${isCenter ? '300px' : '240px'}; ${isCenter ? `border: 2px solid var(--lp-primary); transform: scale(1.05); z-index: 1; box-shadow: 0 8px 32px color-mix(in srgb, var(--lp-primary) 20%, transparent)` : 'border: 1px solid color-mix(in srgb, var(--lp-text) 10%, transparent)'}`}>
            {isCenter && (plan.badge || 'Most Popular') && <span style="font-size: 0.7rem; font-weight: 700; text-transform: uppercase; letter-spacing: 0.08em; color: var(--lp-primary); margin-bottom: 0.5rem">{plan.badge || 'Most Popular'}</span>}
            <h3 class={`font-semibold ${isCenter ? 'text-xl' : 'text-lg'}`}>{plan.name}</h3>
            <div class="mt-2 flex items-baseline gap-1">
              <span class={`font-bold ${isCenter ? 'text-4xl' : 'text-2xl'}`}>{plan.price}</span>
              {plan.period && <span class="text-sm" style="color: var(--lp-text-muted)">{plan.period}</span>}
            </div>
            {plan.description && <p class="mt-2 text-sm" style="color: var(--lp-text-muted)">{plan.description}</p>}
            <ul class="mt-4 flex-1 space-y-2 text-sm">
              {(plan.features ?? []).map((f) => <li class="flex items-start gap-2"><span style="color: var(--lp-primary)">✓</span>{f}</li>)}
            </ul>
            <a
              href={plan.cta?.url}
              class={isCenter ? 'landing-btn-primary mt-6' : ''}
              style={isCenter ? 'display: block; text-align: center' : `margin-top: 1.5rem; display: block; text-align: center; padding: 0.5rem; border-radius: var(--lp-radius); font-size: 0.85rem; font-weight: 600; text-decoration: none; background: color-mix(in srgb, var(--lp-text) 8%, transparent)`}
            >{plan.cta?.text}</a>
          </div>
        )
      })}
    </div>
  </section>
)}
