---
/**
 * Section renderer — maps section type string to Astro component,
 * sorts by order, filters disabled sections, renders in sequence.
 * Nav renders at top, footer at bottom, both receive all sections for context.
 * Each section gets id="section-{type}" for anchor link navigation.
 */
import LandingHero from './landing-hero.astro'
import LandingFeatures from './landing-features.astro'
import LandingPricing from './landing-pricing.astro'
import LandingTestimonials from './landing-testimonials.astro'
import LandingFaq from './landing-faq.astro'
import LandingCta from './landing-cta.astro'
import LandingStats from './landing-stats.astro'
import LandingHowItWorks from './landing-how-it-works.astro'
import LandingTeam from './landing-team.astro'
import LandingLogoWall from './landing-logo-wall.astro'
import LandingNav from './landing-nav.astro'
import LandingFooter from './landing-footer.astro'
import LandingVideo from './landing-video.astro'
import LandingImage from './landing-image.astro'
import LandingImageText from './landing-image-text.astro'
import LandingGallery from './landing-gallery.astro'
import LandingMap from './landing-map.astro'
import LandingRichText from './landing-rich-text.astro'
import LandingDivider from './landing-divider.astro'
import LandingCountdown from './landing-countdown.astro'
import LandingContactForm from './landing-contact-form.astro'
import LandingBanner from './landing-banner.astro'
import LandingComparison from './landing-comparison.astro'
import LandingAiSearch from './landing-ai-search.astro'
import LandingLayout from './landing-layout.astro'
import LandingSocialProof from './landing-social-proof.astro'
import LandingPopup from './landing-popup.astro'
import LandingProductShowcase from './landing-product-showcase.astro'
import type { LandingSection, SectionStyle } from '@/lib/landing/landing-types'
import { sanitizeCss } from '@/lib/landing/css-sanitizer'

import '@/styles/landing.css'

interface Props {
  sections: LandingSection[]
  pageTitle?: string
  /** AI-generated scoped CSS blocks for visual fidelity */
  scopedCss?: Array<{ selector: string; css: string }>
}

const { sections, pageTitle, scopedCss } = Astro.props

/** Build scoped CSS string — each block wrapped in its selector */
function buildScopedCssString(blocks?: Array<{ selector: string; css: string }>): string {
  if (!blocks?.length) return ''
  return blocks.map(b => `${b.selector} { ${b.css} }`).join('\n')
}
const enabled = sections.filter(s => s.enabled !== false)

// Nav and footer are special — rendered outside the main sections flow
const navSection = enabled.find(s => s.type === 'nav')
const footerSection = enabled.find(s => s.type === 'footer')

// Popup sections — rendered outside body flow as overlays
const popupSections = enabled.filter(s => s.type === 'popup')

// Body sections — everything except nav, footer, and popup, sorted by order
const bodySections = enabled
  .filter(s => s.type !== 'nav' && s.type !== 'footer' && s.type !== 'popup')
  .sort((a, b) => a.order - b.order)

// Track type counts to generate unique IDs (e.g. section-cta, section-cta-2)
const typeCounts = new Map<string, number>()
function uniqueSectionId(type: string): string {
  const count = (typeCounts.get(type) || 0) + 1
  typeCounts.set(type, count)
  return count === 1 ? `section-${type}` : `section-${type}-${count}`
}

/** Build inline style string from per-section style overrides */
function buildSectionStyle(style?: SectionStyle): string | undefined {
  if (!style) return undefined
  const parts: string[] = []
  if (style.background) parts.push(`background: ${style.background}`)
  // Padding goes on .landing-section (inner), not the wrapper — prevents bg bleed gaps
  // Only set padding on wrapper for bg-image sections (where .landing-section has padding:0)
  if (style.backgroundImage && style.padding) parts.push(`padding: ${style.padding}`)
  if (style.textColor) parts.push(`--lp-text: ${style.textColor}; color: ${style.textColor}`)
  if (style.textMutedColor) parts.push(`--lp-text-muted: ${style.textMutedColor}`)
  if (style.accentColor) parts.push(`--lp-accent: ${style.accentColor}`)
  if (style.backgroundImage) parts.push('position: relative; overflow: hidden')
  return parts.length > 0 ? parts.join('; ') : undefined
}

/** Returns true when textColor is white-ish — signals a dark background section */
function isDarkSection(style?: SectionStyle): boolean {
  if (!style?.textColor) return false
  const c = style.textColor.trim().toLowerCase()
  return c === '#fff' || c === '#ffffff' || c === 'white' || c === 'rgb(255,255,255)' || c === 'rgb(255, 255, 255)'
}

const componentMap: Record<string, any> = {
  hero: LandingHero,
  features: LandingFeatures,
  pricing: LandingPricing,
  testimonials: LandingTestimonials,
  faq: LandingFaq,
  cta: LandingCta,
  stats: LandingStats,
  'how-it-works': LandingHowItWorks,
  team: LandingTeam,
  'logo-wall': LandingLogoWall,
  video: LandingVideo,
  image: LandingImage,
  'image-text': LandingImageText,
  gallery: LandingGallery,
  map: LandingMap,
  'rich-text': LandingRichText,
  divider: LandingDivider,
  countdown: LandingCountdown,
  'contact-form': LandingContactForm,
  banner: LandingBanner,
  comparison: LandingComparison,
  'ai-search': LandingAiSearch,
  layout: LandingLayout,
  'social-proof': LandingSocialProof,
  popup: LandingPopup,
  'product-showcase': LandingProductShowcase,
}
---

{/* Nav at top — receives all sections for auto-generating anchor links */}
{navSection && <LandingNav {...navSection.data as any} sections={enabled} pageTitle={pageTitle} sectionStyle={navSection.style} />}

<div class="landing-sections">
  {bodySections.map(section => {
    const Component = componentMap[section.type]
    if (!Component) return null
    const s = section.style
    const isFullWidth = s?.fullWidth
    const hasBgImage = !!s?.backgroundImage
    const sectionId = uniqueSectionId(section.type)
    const inlineStyle = buildSectionStyle(s)
    return (
      <div
        id={sectionId}
        data-section={sectionId}
        class:list={['lp-full-width', hasBgImage ? 'lp-section-bg' : '', 'lp-fade-up', isDarkSection(s) ? 'lp-dark-section' : '']}
        style={inlineStyle}
      >
        {/* Background image + overlay (rendered before content) */}
        {hasBgImage && (
          <div class="lp-section-bg-img" style={`background-image: url(${s!.backgroundImage}); background-size: cover; background-position: center`} />
        )}
        {hasBgImage && s?.backgroundOverlay && (
          <div class="lp-section-bg-overlay" style={`background: ${s.backgroundOverlay}`} />
        )}
        <div class={hasBgImage ? 'lp-section-content' : ''}>
          <Component {...section.data as any} />
        </div>
      </div>
    )
  })}
</div>

{/* Footer at bottom */}
{footerSection && (
  <div id="section-footer" data-section="section-footer" class={footerSection.style?.fullWidth ? 'lp-full-width' : ''} style={buildSectionStyle(footerSection.style)}>
    <LandingFooter {...footerSection.data as any} pageTitle={pageTitle} />
  </div>
)}

{/* Popup overlays — rendered outside body/footer flow */}
{popupSections.map(s => <LandingPopup {...s.data as any} pageSlug={pageTitle} />)}

{/* AI-generated scoped CSS for visual fidelity */}
{scopedCss && scopedCss.length > 0 && (
  <style set:html={sanitizeCss(buildScopedCssString(scopedCss))} />
)}
