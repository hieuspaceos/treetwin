---
/**
 * Features section with 3 layout variants:
 * - grid (default): card grid layout
 * - list: vertical list with icon left, text right
 * - alternating: zigzag rows (image/icon alternates sides)
 */
import type { FeaturesData } from '@/lib/landing/landing-types'

interface Props extends FeaturesData {}
const { heading, subheading, items = [], columns = 3, variant = 'grid' } = Astro.props
const gridClass = `landing-grid-${columns}` as const
---

{/* Grid: default card grid */}
{variant === 'grid' && (
  <section class="landing-section">
    {heading && <h2 class="mb-2 text-center text-3xl font-bold">{heading}</h2>}
    {subheading && <p class="mx-auto mb-8 max-w-2xl text-center" style="color: var(--lp-text-muted)">{subheading}</p>}
    <div class={gridClass}>
      {items.map((item) => (
        <div class="lp-card-hover p-6" style="background: color-mix(in srgb, var(--lp-primary) 5%, var(--lp-surface)); border-radius: var(--lp-radius); border: 1px solid color-mix(in srgb, var(--lp-primary) 8%, transparent)">
          {item.icon && (item.icon.startsWith('http') ? <img src={item.icon} alt={item.title} class="mb-3 h-10 w-10 object-contain" /> : <div class="lp-icon-bg mb-3">{item.icon}</div>)}
          <h3 class="mb-2 text-lg font-semibold">{item.title}</h3>
          <p class="text-sm" style="color: var(--lp-text-muted); line-height: 1.7">{item.description}</p>
          {item.price && (
            <div style="margin-top: 1.25rem; padding-top: 1.25rem; border-top: 1px solid color-mix(in srgb, var(--lp-text) 10%, transparent); display: flex; align-items: center; justify-content: space-between">
              <span style="font-size: 0.9375rem; color: var(--lp-accent, var(--lp-primary)); font-weight: 500">{item.price}</span>
              {item.priceType && (
                <span style="font-size: 0.75rem; color: var(--lp-text-muted); background: color-mix(in srgb, var(--lp-text) 5%, transparent); padding: 0.25rem 0.625rem; border-radius: 100px">{item.priceType}</span>
              )}
            </div>
          )}
        </div>
      ))}
    </div>
  </section>
)}

{/* List: vertical list, icon left + text right */}
{variant === 'list' && (
  <section class="landing-section">
    {heading && <h2 class="mb-2 text-center text-3xl font-bold">{heading}</h2>}
    {subheading && <p class="mx-auto mb-8 max-w-2xl text-center" style="color: var(--lp-text-muted)">{subheading}</p>}
    <div class="mx-auto max-w-3xl" style="display: flex; flex-direction: column; gap: 1rem">
      {items.map((item) => (
        <div style="display: flex; align-items: flex-start; gap: 1.25rem; padding: 1.25rem; background: color-mix(in srgb, var(--lp-primary) 5%, var(--lp-surface)); border-radius: var(--lp-radius)">
          {item.icon && (
            item.icon.startsWith('http') ? <img src={item.icon} alt={item.title} style="width: 2.5rem; height: 2.5rem; object-fit: contain; flex-shrink: 0" /> : <span style="font-size: 1.75rem; flex-shrink: 0; width: 2.5rem; text-align: center">{item.icon}</span>
          )}
          {!item.icon && (
            <span style="width: 2.5rem; height: 2.5rem; flex-shrink: 0; border-radius: 50%; background: color-mix(in srgb, var(--lp-primary) 15%, transparent); display: flex; align-items: center; justify-content: center; font-size: 0.8rem; font-weight: 700; color: var(--lp-primary)">✓</span>
          )}
          <div>
            <h3 class="mb-1 text-base font-semibold">{item.title}</h3>
            <p class="text-sm" style="color: var(--lp-text-muted)">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
)}

{/* Alternating: zigzag rows */}
{variant === 'alternating' && (
  <section class="landing-section">
    {heading && <h2 class="mb-2 text-center text-3xl font-bold">{heading}</h2>}
    {subheading && <p class="mx-auto mb-8 max-w-2xl text-center" style="color: var(--lp-text-muted)">{subheading}</p>}
    <div style="display: flex; flex-direction: column; gap: 2.5rem">
      {items.map((item, i) => (
        <div style={`display: flex; align-items: center; gap: 2rem; flex-wrap: wrap; flex-direction: ${i % 2 === 1 ? 'row-reverse' : 'row'}`}>
          <div style="flex: 1; min-width: 220px; display: flex; align-items: center; justify-content: center; font-size: 4rem; padding: 2rem; background: color-mix(in srgb, var(--lp-primary) 8%, var(--lp-surface)); border-radius: var(--lp-radius)">
            {item.icon || '✦'}
          </div>
          <div style="flex: 2; min-width: 220px">
            <h3 class="mb-2 text-xl font-bold">{item.title}</h3>
            <p style="color: var(--lp-text-muted); line-height: 1.7">{item.description}</p>
          </div>
        </div>
      ))}
    </div>
  </section>
)}
