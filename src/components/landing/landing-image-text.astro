---
import type { ImageTextData } from '@/lib/landing/landing-types'

interface Props extends ImageTextData {}
const { image, heading, text, imagePosition = 'left', cta } = Astro.props
---

<section class="landing-section glass-panel rounded-2xl">
  <div class={`flex flex-col gap-8 md:flex-row ${imagePosition === 'right' ? 'md:flex-row-reverse' : ''}`}>
    <div class="flex-1">
      {image?.src && <img src={image.src} alt={image.alt || ''} class="w-full rounded-xl object-cover" loading="lazy" />}
    </div>
    <div class="flex flex-1 flex-col justify-center">
      {heading && <h2 class="mb-4 text-3xl font-bold text-slate-900">{heading}</h2>}
      <p class="text-slate-600 leading-relaxed">{text}</p>
      {cta && (
        <a href={cta.url} class="mt-6 inline-block rounded-xl bg-green-600 px-6 py-2.5 text-white font-semibold hover:bg-green-700 transition-colors self-start">
          {cta.text}
        </a>
      )}
    </div>
  </div>
</section>
