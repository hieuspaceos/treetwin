---
import type { MapData } from '@/lib/landing/landing-types'

interface Props extends MapData {}
const { address, embedUrl, height = 400 } = Astro.props

/** Extract URL from iframe tag if user pasted full embed code */
function extractUrl(input?: string): string | undefined {
  if (!input) return undefined
  const match = input.match(/src=["']([^"']+)["']/)
  return match ? match[1] : input
}

/** Google Maps embed — works without API key via maps.google.com */
const cleanUrl = extractUrl(embedUrl)
const src = cleanUrl || (address
  ? `https://maps.google.com/maps?q=${encodeURIComponent(address)}&t=&z=13&ie=UTF8&iwloc=&output=embed`
  : null)
---

<section class="landing-section">
  {src ? (
    <iframe
      src={src}
      width="100%"
      height={height}
      class="rounded-xl border-0 w-full"
      style={`height:${height}px`}
      loading="lazy"
      referrerpolicy="no-referrer-when-downgrade"
      allowfullscreen
      title={address || 'Map'}
    />
  ) : (
    <div class="flex items-center justify-center rounded-xl bg-slate-100 text-slate-400 text-sm" style={`height:${height}px`}>
      No map address or embed URL provided
    </div>
  )}
  {address && <p class="mt-2 text-center text-sm text-slate-500">{address}</p>}
</section>
