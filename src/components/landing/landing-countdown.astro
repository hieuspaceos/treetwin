---
import type { CountdownData } from '@/lib/landing/landing-types'

interface Props extends CountdownData {}
const { targetDate, heading, expiredText = 'This offer has expired.' } = Astro.props
---

<section class="landing-section glass-panel rounded-2xl text-center">
  {heading && <h2 class="mb-6 text-3xl font-bold text-slate-900">{heading}</h2>}
  <div id="countdown-display" class="flex justify-center gap-6" role="timer" aria-live="polite" aria-atomic="true" data-target={targetDate} data-expired={expiredText}>
    {(['Days','Hours','Mins','Secs'] as const).map((label) => (
      <div class="flex flex-col items-center">
        <span class="countdown-unit text-5xl font-black text-green-600 tabular-nums" data-unit={label.toLowerCase()}>--</span>
        <span class="mt-1 text-xs uppercase tracking-widest text-slate-400">{label}</span>
      </div>
    ))}
  </div>
</section>

<script>
  const el = document.getElementById('countdown-display')
  if (el) {
    const target = new Date(el.dataset.target!).getTime()
    const expired = el.dataset.expired!
    function tick() {
      const diff = target - Date.now()
      if (diff <= 0) { el!.innerHTML = `<p class="text-slate-500">${expired}</p>`; return }
      const d = Math.floor(diff / 86400000)
      const h = Math.floor((diff % 86400000) / 3600000)
      const m = Math.floor((diff % 3600000) / 60000)
      const s = Math.floor((diff % 60000) / 1000)
      const pad = (n: number) => String(n).padStart(2, '0')
      ;(['days','hours','mins','secs'] as const).forEach((unit, i) => {
        const span = el!.querySelector<HTMLElement>(`[data-unit="${unit}"]`)
        if (span) span.textContent = pad([d, h, m, s][i])
      })
    }
    tick(); setInterval(tick, 1000)
  }
</script>
