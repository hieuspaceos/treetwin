---
/**
 * Landing page nav section with 5 layout variants:
 * - default: logo left, links right (sticky with background)
 * - centered: logo centered, links split left/right
 * - transparent: no background, overlay style (for hero-over use)
 * - hamburger: always hamburger icon, full-screen overlay menu (→ landing-nav-hamburger.astro)
 * - mega: desktop dropdown panels with grouped links; hamburger on mobile
 */
import type { NavData, LandingSection, SectionStyle } from '@/lib/landing/landing-types'
import NavHamburger from './landing-nav-hamburger.astro'
import NavMega from './landing-nav-mega.astro'

interface Props extends NavData {
  sections?: LandingSection[]
  pageTitle?: string
  sectionStyle?: SectionStyle
}

const { brandName, logo, topBar, links, sections = [], pageTitle, variant = 'default', socialLinks = [], sectionStyle, groups = [], cta } = Astro.props

/** Build inline style from section style overrides (background, textColor, padding) */
const navStyleParts: string[] = []
if (sectionStyle?.background) navStyleParts.push(`background: ${sectionStyle.background}`)
if (sectionStyle?.padding) navStyleParts.push(`padding: ${sectionStyle.padding}`)
const navInlineStyle = navStyleParts.length > 0 ? navStyleParts.join('; ') : undefined
/** Text color for nav links — from section style or variant defaults */
const linkColor = sectionStyle?.textColor || (variant === 'transparent' ? 'rgba(255,255,255,0.85)' : 'var(--lp-text-muted)')
const brandColor = sectionStyle?.textColor || (variant === 'transparent' ? '#fff' : 'var(--lp-text)')

const sectionLabels: Record<string, string> = {
  features: 'Features', pricing: 'Pricing', testimonials: 'Testimonials',
  faq: 'FAQ', stats: 'Stats', 'how-it-works': 'How It Works',
  team: 'Team', 'logo-wall': 'Partners',
}

const skipTypes = new Set(['hero', 'nav', 'footer', 'cta'])
const autoLinks = links && links.length > 0
  ? links
  : sections
      .filter(s => s.enabled !== false && !skipTypes.has(s.type))
      .sort((a, b) => a.order - b.order)
      .map(s => ({ label: sectionLabels[s.type] || s.type, href: `#section-${s.type}` }))

const brand = brandName || pageTitle || 'Home'
/** Render brand as logo image or text */
const brandLogo = logo
  ? `<img src="${logo}" alt="${brand}" style="height: 40px; width: auto; object-fit: contain" />`
  : null
---

{/* Top info bar — rendered above nav when topBar data exists */}
{topBar && topBar.length > 0 && (
  <div style={`display: flex; justify-content: center; gap: 1.5rem; padding: 0.4rem 1rem; font-size: 0.75rem; background: ${sectionStyle?.background ? 'color-mix(in srgb, ' + sectionStyle.background + ' 80%, #000)' : '#1e3a2f'}; color: rgba(255,255,255,0.8)`}>
    {topBar.map(item => {
      const iconEl = item.icon
        ? (item.icon.startsWith('http') ? <img src={item.icon} alt="" style="height:14px;width:auto" /> : <span>{item.icon}</span>)
        : null
      return item.href
        ? <a href={item.href} style="color: rgba(255,255,255,0.8); text-decoration: none; display: inline-flex; align-items: center; gap: 0.3rem">{iconEl}{item.text}</a>
        : <span style="display: inline-flex; align-items: center; gap: 0.3rem">{iconEl}{item.text}</span>
    })}
  </div>
)}
{/* Default: logo left, links right */}
{variant === 'default' && (
  <nav class="landing-nav sticky top-0 z-50" style={navInlineStyle} aria-label="Landing page navigation">
    <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-3">
      <a href="#" class="text-lg font-semibold tracking-tight" style={`color: ${brandColor}`}>
        {brandLogo ? <Fragment set:html={brandLogo} /> : brand}
      </a>
      {/* Desktop links — hidden on mobile */}
      <div class="hidden items-center gap-1 sm:flex">
        {autoLinks.map(link => (
          <a href={link.href} class="rounded-full px-3 py-1.5 text-sm font-medium transition-colors" style={`color: ${linkColor}`}>{link.label}</a>
        ))}
        {socialLinks.length > 0 && (
          <span style="display:inline-flex;gap:0.25rem;margin-left:0.5rem">
            {socialLinks.map(sl => (
              <a href={sl.url} target="_blank" rel="noopener noreferrer" title={sl.label || sl.icon}
                style="font-size:1.1rem;line-height:1;padding:4px;border-radius:6px;transition:opacity 0.2s;color:var(--lp-text-muted)"
                aria-label={sl.label || sl.icon}>{sl.icon?.startsWith('http') ? <img src={sl.icon} alt={sl.label || ''} style="height:18px;width:18px;object-fit:contain" /> : sl.icon}</a>
            ))}
          </span>
        )}
        {cta && (
          <a href={cta.url} style={`margin-left:0.5rem;padding:0.45rem 1rem;border-radius:8px;font-size:0.85rem;font-weight:500;text-decoration:none;background:color-mix(in srgb, var(--lp-accent, var(--lp-primary)) 15%, transparent);border:1px solid color-mix(in srgb, var(--lp-accent, var(--lp-primary)) 25%, transparent);color:var(--lp-accent, var(--lp-primary));transition:all 0.2s`}>
            {cta.text}
          </a>
        )}
      </div>
      {/* Hamburger button — visible only on mobile */}
      <button
        class="lp-hamburger-btn sm:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="lp-mobile-menu-default"
        style={`color: ${brandColor}`}
      >
        <span class="lp-hamburger-icon">&#9776;</span>
      </button>
    </div>
    {/* Mobile overlay menu */}
    <div
      id="lp-mobile-menu-default"
      class="lp-mobile-menu"
      role="dialog"
      aria-label="Mobile navigation"
      aria-modal="true"
      aria-hidden="true"
    >
      <div class="lp-mobile-menu-inner">
        <button class="lp-mobile-close" aria-label="Close menu">&#10005;</button>
        {autoLinks.map(link => (
          <a href={link.href} class="lp-mobile-link">{link.label}</a>
        ))}
        {socialLinks.length > 0 && (
          <div class="lp-mobile-social">
            {socialLinks.map(sl => (
              <a href={sl.url} target="_blank" rel="noopener noreferrer"
                aria-label={sl.label || sl.icon} style="font-size:1.3rem;color:var(--lp-text-muted)">
                {sl.icon?.startsWith('http') ? <img src={sl.icon} alt={sl.label || ''} style="height:20px;width:20px;object-fit:contain" loading="lazy" decoding="async" /> : sl.icon}
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </nav>
)}

{/* Centered: logo centered, links split left/right */}
{variant === 'centered' && (
  <nav class="landing-nav sticky top-0 z-50" style={navInlineStyle} aria-label="Landing page navigation">
    <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-3" style="position: relative">
      {/* Left links (first half) — hidden on mobile */}
      <div class="hidden items-center gap-1 sm:flex" style="flex: 1">
        {autoLinks.slice(0, Math.ceil(autoLinks.length / 2)).map(link => (
          <a href={link.href} class="rounded-full px-2 py-1.5 text-xs font-medium transition-colors" style={`color: ${linkColor}`}>{link.label}</a>
        ))}
      </div>
      {/* Center brand */}
      <a href="#" class="text-lg font-semibold tracking-tight" style={`color: ${brandColor}; flex-shrink: 0; padding: 0 1rem`}>
        {brandLogo ? <Fragment set:html={brandLogo} /> : brand}
      </a>
      {/* Right links (second half) + social links — hidden on mobile */}
      <div class="hidden items-center gap-1 sm:flex" style="flex: 1; justify-content: flex-end">
        {autoLinks.slice(Math.ceil(autoLinks.length / 2)).map(link => (
          <a href={link.href} class="rounded-full px-2 py-1.5 text-xs font-medium transition-colors" style={`color: ${linkColor}`}>{link.label}</a>
        ))}
        {socialLinks.map(sl => (
          <a href={sl.url} target="_blank" rel="noopener noreferrer" title={sl.label || sl.icon}
            style="font-size:1.1rem;line-height:1;padding:4px;border-radius:6px;transition:opacity 0.2s;color:var(--lp-text-muted)"
            aria-label={sl.label || sl.icon}>{sl.icon}</a>
        ))}
      </div>
      {/* Hamburger button — visible only on mobile */}
      <button
        class="lp-hamburger-btn sm:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="lp-mobile-menu-centered"
        style={`color: ${brandColor}`}
      >
        <span class="lp-hamburger-icon">&#9776;</span>
      </button>
    </div>
    {/* Mobile overlay menu */}
    <div
      id="lp-mobile-menu-centered"
      class="lp-mobile-menu"
      role="dialog"
      aria-label="Mobile navigation"
      aria-modal="true"
      aria-hidden="true"
    >
      <div class="lp-mobile-menu-inner">
        <button class="lp-mobile-close" aria-label="Close menu">&#10005;</button>
        {autoLinks.map(link => (
          <a href={link.href} class="lp-mobile-link">{link.label}</a>
        ))}
        {socialLinks.length > 0 && (
          <div class="lp-mobile-social">
            {socialLinks.map(sl => (
              <a href={sl.url} target="_blank" rel="noopener noreferrer"
                aria-label={sl.label || sl.icon} style="font-size:1.3rem;color:var(--lp-text-muted)">
                {sl.icon?.startsWith('http') ? <img src={sl.icon} alt={sl.label || ''} style="height:20px;width:20px;object-fit:contain" loading="lazy" decoding="async" /> : sl.icon}
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </nav>
)}

{/* Transparent: no background, overlay style */}
{variant === 'transparent' && (
  <nav class="sticky top-0 z-50" style="background: transparent; border-bottom: none" aria-label="Landing page navigation">
    <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
      <a href="#" class="text-lg font-semibold tracking-tight" style="color: #fff; text-shadow: 0 1px 4px rgba(0,0,0,0.4)">
        {brandLogo ? <Fragment set:html={brandLogo} /> : brand}
      </a>
      {/* Desktop links — hidden on mobile */}
      <div class="hidden items-center gap-1 sm:flex">
        {autoLinks.map(link => (
          <a href={link.href} class="rounded-full px-3 py-1.5 text-sm font-medium transition-colors" style="color: rgba(255,255,255,0.85)">{link.label}</a>
        ))}
        {socialLinks.map(sl => (
          <a href={sl.url} target="_blank" rel="noopener noreferrer" title={sl.label || sl.icon}
            style="font-size:1.1rem;line-height:1;padding:4px;border-radius:6px;transition:opacity 0.2s;color:rgba(255,255,255,0.85)"
            aria-label={sl.label || sl.icon}>{sl.icon}</a>
        ))}
      </div>
      {/* Hamburger button — visible only on mobile */}
      <button
        class="lp-hamburger-btn sm:hidden"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="lp-mobile-menu-transparent"
        style="color: #fff"
      >
        <span class="lp-hamburger-icon">&#9776;</span>
      </button>
    </div>
    {/* Mobile overlay menu */}
    <div
      id="lp-mobile-menu-transparent"
      class="lp-mobile-menu"
      role="dialog"
      aria-label="Mobile navigation"
      aria-modal="true"
      aria-hidden="true"
    >
      <div class="lp-mobile-menu-inner">
        <button class="lp-mobile-close" aria-label="Close menu">&#10005;</button>
        {autoLinks.map(link => (
          <a href={link.href} class="lp-mobile-link" style="color: rgba(255,255,255,0.9)">{link.label}</a>
        ))}
        {socialLinks.length > 0 && (
          <div class="lp-mobile-social">
            {socialLinks.map(sl => (
              <a href={sl.url} target="_blank" rel="noopener noreferrer"
                aria-label={sl.label || sl.icon} style="font-size:1.3rem;color:rgba(255,255,255,0.7)">
                {sl.icon?.startsWith('http') ? <img src={sl.icon} alt={sl.label || ''} style="height:20px;width:20px;object-fit:contain" loading="lazy" decoding="async" /> : sl.icon}
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </nav>
)}

<style>
  /* Hamburger button */
  .lp-hamburger-btn {
    align-items: center;
    justify-content: center;
    width: 2.25rem;
    height: 2.25rem;
    background: none;
    border: none;
    border-radius: 6px;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s;
  }
  /* Show only on mobile — match Tailwind sm:hidden breakpoint */
  @media (min-width: 640px) {
    .lp-hamburger-btn { display: none !important; }
  }
  @media (max-width: 639px) {
    .lp-hamburger-btn { display: flex; }
  }
  .lp-hamburger-btn:hover {
    background: rgba(128,128,128,0.12);
  }
  .lp-hamburger-icon {
    font-size: 1.3rem;
    line-height: 1;
  }

  /* Mobile overlay menu — hidden by default.
     Uses top/left/width/height instead of inset to escape sticky/backdrop-filter containing block. */
  .lp-mobile-menu {
    display: none;
    position: fixed;
    top: 0;
    left: 0;
    width: 100vw;
    height: 100vh;
    z-index: 9999;
    background: rgba(10, 12, 20, 0.96);
    animation: lpMobileSlideDown 0.25s ease forwards;
  }
  .lp-mobile-menu.is-open {
    display: flex;
    flex-direction: column;
  }
  @keyframes lpMobileSlideDown {
    from { opacity: 0; transform: translateY(-8px); }
    to   { opacity: 1; transform: translateY(0); }
  }

  /* Inner content: close button + links */
  .lp-mobile-menu-inner {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1.25rem;
    flex: 1;
    padding: 2rem;
  }

  /* Close button */
  .lp-mobile-close {
    position: absolute;
    top: 1rem;
    right: 1.25rem;
    background: none;
    border: none;
    font-size: 1.5rem;
    color: rgba(255,255,255,0.7);
    cursor: pointer;
    padding: 0.25rem;
    border-radius: 6px;
    transition: color 0.2s;
    line-height: 1;
  }
  .lp-mobile-close:hover { color: #fff; }

  /* Mobile nav links — always white on dark overlay */
  .lp-mobile-link {
    font-size: 1.25rem;
    font-weight: 600;
    color: rgba(255, 255, 255, 0.9) !important;
    text-decoration: none;
    padding: 0.5rem 1.5rem;
    border-radius: 8px;
    text-align: center;
    transition: background 0.2s;
    width: 100%;
    max-width: 280px;
  }
  .lp-mobile-link:hover {
    background: rgba(255,255,255,0.08);
  }

  /* Social links row in mobile menu */
  .lp-mobile-social {
    display: flex;
    gap: 1rem;
    margin-top: 0.5rem;
  }
</style>

<script>
  /* Mobile nav toggle — shared by default, centered, transparent variants */
  document.addEventListener('DOMContentLoaded', () => {
    const hamburgers = document.querySelectorAll<HTMLButtonElement>('.lp-hamburger-btn')
    hamburgers.forEach(btn => {
      const menuId = btn.getAttribute('aria-controls')
      if (!menuId) return
      const menu = document.getElementById(menuId)
      if (!menu) return

      function openMenu() {
        menu!.classList.add('is-open')
        menu!.setAttribute('aria-hidden', 'false')
        btn.setAttribute('aria-expanded', 'true')
        document.body.style.overflow = 'hidden'
      }
      function closeMenu() {
        menu!.classList.remove('is-open')
        menu!.setAttribute('aria-hidden', 'true')
        btn.setAttribute('aria-expanded', 'false')
        document.body.style.overflow = ''
      }

      btn.addEventListener('click', openMenu)

      const closeBtn = menu.querySelector('.lp-mobile-close')
      closeBtn?.addEventListener('click', closeMenu)

      /* Close on anchor link click */
      menu.querySelectorAll('.lp-mobile-link').forEach(link => {
        link.addEventListener('click', closeMenu)
      })

      /* Close on Escape key */
      document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape' && menu!.classList.contains('is-open')) closeMenu()
      })

      /* Close on backdrop click (outside inner content) */
      menu.addEventListener('click', (e) => {
        if (e.target === menu) closeMenu()
      })
    })
  })
</script>

{/* Hamburger: always icon, full-screen overlay — delegated */}
{variant === 'hamburger' && (
  <NavHamburger
    brandName={brandName} logo={logo} topBar={topBar} links={links}
    sections={sections} pageTitle={pageTitle} variant={variant}
    socialLinks={socialLinks} sectionStyle={sectionStyle}
    autoLinks={autoLinks} brand={brand} brandLogo={brandLogo}
    navInlineStyle={navInlineStyle} brandColor={brandColor}
  />
)}

{/* Mega: dropdown panels with groups; hamburger on mobile — delegated */}
{variant === 'mega' && (
  <NavMega
    brandName={brandName} logo={logo} topBar={topBar} links={links}
    sections={sections} pageTitle={pageTitle} variant={variant}
    socialLinks={socialLinks} sectionStyle={sectionStyle} groups={groups}
    autoLinks={autoLinks} brand={brand} brandLogo={brandLogo}
    navInlineStyle={navInlineStyle} brandColor={brandColor} linkColor={linkColor}
  />
)}
