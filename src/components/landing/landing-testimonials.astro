---
/**
 * Testimonials section with 3 layout variants:
 * - cards (default): grid of quote cards with avatars
 * - single: one large quote centered (uses first item)
 * - minimal: text-only quotes, no avatars
 */
import type { TestimonialsData } from '@/lib/landing/landing-types'

interface Props extends TestimonialsData {}
const { heading, items, variant = 'cards' } = Astro.props
---

{/* Cards: default grid with avatars */}
{variant === 'cards' && (
  <section class="landing-section">
    {heading && <h2 class="mb-8 text-center text-3xl font-bold">{heading}</h2>}
    <div class="landing-grid-2">
      {items.map((t) => (
        <div class="glass-card p-6">
          <p class="mb-4 italic" style="color: var(--lp-text-muted)">"{t.quote}"</p>
          <div class="flex items-center gap-3">
            {t.avatar && <img src={t.avatar} alt={t.name} class="h-10 w-10 rounded-full object-cover" />}
            <div>
              <p class="text-sm font-semibold">{t.name}</p>
              {(t.role || t.company) && (
                <p class="text-xs" style="color: var(--lp-text-muted)">{[t.role, t.company].filter(Boolean).join(' · ')}</p>
              )}
            </div>
          </div>
        </div>
      ))}
    </div>
  </section>
)}

{/* Single: one large centered quote */}
{variant === 'single' && (
  <section class="landing-section text-center">
    {heading && <h2 class="mb-8 text-3xl font-bold">{heading}</h2>}
    {items.length > 0 && (
      <div style="max-width: 680px; margin: 0 auto; padding: 2.5rem; background: var(--lp-surface); border-radius: var(--lp-radius)">
        <p style="font-size: 1.35rem; font-style: italic; line-height: 1.7; color: var(--lp-text); margin-bottom: 1.5rem">
          "{items[0].quote}"
        </p>
        <div style="display: flex; align-items: center; justify-content: center; gap: 0.75rem">
          {items[0].avatar && <img src={items[0].avatar} alt={items[0].name} style="width: 3rem; height: 3rem; border-radius: 50%; object-fit: cover" />}
          <div style="text-align: left">
            <p class="font-semibold">{items[0].name}</p>
            {(items[0].role || items[0].company) && (
              <p class="text-sm" style="color: var(--lp-text-muted)">{[items[0].role, items[0].company].filter(Boolean).join(' · ')}</p>
            )}
          </div>
        </div>
      </div>
    )}
  </section>
)}

{/* Minimal: text-only quotes, no avatars */}
{variant === 'minimal' && (
  <section class="landing-section">
    {heading && <h2 class="mb-8 text-center text-3xl font-bold">{heading}</h2>}
    <div style="display: flex; flex-direction: column; gap: 1.5rem; max-width: 640px; margin: 0 auto">
      {items.map((t) => (
        <div style="padding: 1.25rem 1.5rem; border-left: 3px solid var(--lp-primary)">
          <p style="font-style: italic; line-height: 1.7; margin-bottom: 0.5rem; color: var(--lp-text)">"{t.quote}"</p>
          <p class="text-sm font-semibold">— {t.name}{t.role ? `, ${t.role}` : ''}</p>
        </div>
      ))}
    </div>
  </section>
)}
