---
import type { HeroData } from '@/lib/landing/landing-types'

interface Props extends HeroData {}
const { headline, subheadline, cta, backgroundImage, embed } = Astro.props
---

<section
  class="landing-section text-center"
  style={backgroundImage ? `background-image: url(${backgroundImage}); background-size: cover; background-position: center;` : undefined}
>
  <h1 class="text-4xl font-bold tracking-tight md:text-5xl lg:text-6xl">
    {headline}
  </h1>
  {subheadline && (
    <p class="mx-auto mt-4 max-w-2xl text-lg" style="color: var(--lp-text-muted)">{subheadline}</p>
  )}
  {cta && (
    <a href={cta.url} class="landing-btn-primary mt-8">
      {cta.text}
    </a>
  )}
  {embed && <div class="mt-8" set:html={embed.replace(/<script[\s\S]*?<\/script>/gi, '')} />}
</section>
