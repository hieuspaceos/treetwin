---
/**
 * Shared <head> content — used by both base-layout and landing-layout.
 * Single source of truth for meta tags, OG, Twitter, fonts, analytics.
 */
import { siteConfig } from '@/config/site-config'
import { checkFeatureEnabled } from '@/lib/admin/feature-guard'

interface Props {
  title: string
  description: string
  canonicalUrl: string
  /** Include RSS link (core site only, not landing pages) */
  includeRss?: boolean
  /** Include JSON-LD structured data (pass pre-built script tag content) */
  jsonLd?: string
}

const { title, description, canonicalUrl, includeRss = false, jsonLd } = Astro.props
---

<meta charset="utf-8" />
<meta name="viewport" content="width=device-width, initial-scale=1" />
<title>{title}</title>
<meta name="description" content={description} />
<link rel="icon" type="image/svg+xml" href="/favicon.svg" />
<link rel="preconnect" href="https://fonts.googleapis.com" />
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;500;600;700&display=swap" rel="stylesheet" media="print" onload="this.media='all'" />
{includeRss && <link rel="alternate" type="application/rss+xml" title={siteConfig.name} href="/rss.xml" />}
<link rel="canonical" href={canonicalUrl} />
<meta property="og:type" content="website" />
<meta property="og:title" content={title} />
<meta property="og:description" content={description} />
<meta property="og:url" content={canonicalUrl} />
<meta name="twitter:card" content="summary_large_image" />
<meta name="twitter:title" content={title} />
<meta name="twitter:description" content={description} />
<meta name="robots" content="max-snippet:-1, max-image-preview:large, max-video-preview:-1" />
{jsonLd && <script is:inline type="application/ld+json" set:html={jsonLd} />}
{siteConfig.analytics.measurementId && checkFeatureEnabled('analytics').enabled && (
  <>
    {includeRss && <meta name="ga-measurement-id" content={siteConfig.analytics.measurementId} />}
    <script is:inline src={`https://www.googletagmanager.com/gtag/js?id=${siteConfig.analytics.measurementId}`} async></script>
    <script is:inline define:vars={{ gaMeasurementId: siteConfig.analytics.measurementId }}>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', gaMeasurementId);
    </script>
  </>
)}
<slot />
