---
import { siteConfig } from '@/config/site-config'
---

<footer class="py-10 text-center text-sm text-slate-400">
  <div class="mx-auto max-w-5xl px-4">
    <div class="glass-panel inline-flex items-center gap-2 rounded-full px-5 py-2.5">
      <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="text-green-500" aria-hidden="true">
        <path d="M12 22V12" /><path d="M12 12L8 8" /><path d="M12 12L16 8" />
        <path d="M12 8L9 5" /><path d="M12 8L15 5" />
        <path d="M12 5L10 3" /><path d="M12 5L14 3" />
      </svg>
      {siteConfig.name} &copy; {new Date().getFullYear()}
    </div>
  </div>
</footer>
