---
/**
 * Landing page layout — standalone layout without core site nav/footer.
 * Used by product landing pages that need their own branding, not the blog nav.
 * Shares <head> with base-layout via BaseHead component.
 */
import { getTheme, themeToStyleVars } from '@/themes/theme-resolver'
import { getActiveThemeId } from '@/lib/get-active-theme-id'
import { siteConfig } from '@/config/site-config'
import BaseHead from '@/components/base-head.astro'
import Analytics from '@vercel/analytics/astro'
import SpeedInsights from '@vercel/speed-insights/astro'
import '@/styles/globals.css'

interface Props {
  title?: string
  description?: string
  /** Optional link for the top-left logo/brand */
  homeHref?: string
  /** Optional brand name override */
  brandName?: string
  /** Optional CTA button in navbar */
  ctaText?: string
  ctaHref?: string
  /** Hide layout nav when page has its own nav section */
  hideNav?: boolean
  /** Hide layout footer when page has its own footer section */
  hideFooter?: boolean
}

const {
  title = siteConfig.name,
  description = siteConfig.description,
  homeHref = '/',
  brandName,
  ctaText,
  ctaHref,
  hideNav = false,
  hideFooter = false,
} = Astro.props

const themeId = getActiveThemeId()
const theme = getTheme(themeId)
const themeVars = themeToStyleVars(theme)
const styleString = Object.entries(themeVars)
  .map(([k, v]) => `${k}:${v}`)
  .join(';')
const canonicalUrl = new URL(Astro.url.pathname, siteConfig.url).href
---

<!doctype html>
<html lang={Astro.currentLocale || 'en'}>
  <head>
    <BaseHead title={title} description={description} canonicalUrl={canonicalUrl}>
      <slot name="head" />
    </BaseHead>
  </head>
  <body>
    <div style={`${styleString};font-family:${theme.fontFamily}`}>
      {/* Layout nav — hidden when page has its own nav section */}
      {!hideNav && (
        <nav class="glass-nav sticky top-0 z-50" aria-label="Main navigation">
          <div class="mx-auto flex max-w-5xl items-center justify-between px-6 py-4">
            <a href={homeHref} class="text-lg font-semibold tracking-tight text-slate-900 transition-opacity hover:opacity-70">
              {brandName || title}
            </a>
            {ctaText && ctaHref && (
              <a
                href={ctaHref}
                class="rounded-xl bg-green-600 px-5 py-2 text-sm font-semibold text-white hover:bg-green-700 transition-colors"
              >
                {ctaText}
              </a>
            )}
          </div>
        </nav>
      )}

      <main class={hideNav ? '' : 'mx-auto max-w-5xl px-4 py-10 sm:px-6'}>
        <slot />
      </main>

      {/* Layout footer — hidden when page has its own footer section */}
      {!hideFooter && (
        <footer class="mx-auto max-w-5xl px-6 py-8 text-center text-sm text-slate-400">
          <p>&copy; {new Date().getFullYear()} {brandName || siteConfig.name}</p>
        </footer>
      )}
    </div>
    <Analytics />
    <SpeedInsights />
  </body>
</html>
