---
/**
 * OAuth callback — Better Auth handles token exchange via /api/auth/callback/*.
 * This page is a fallback redirect in case users land here directly.
 */
export const prerender = false

const raw = Astro.url.searchParams.get('redirect') || '/dashboard'
const target = raw.startsWith('/') && !raw.startsWith('//') ? raw : '/dashboard'
return Astro.redirect(target)
---
