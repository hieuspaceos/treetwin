---
/**
 * Login page — Google OAuth via Better Auth.
 * Redirects to /dashboard after successful sign-in.
 */
import BaseLayout from '@/layouts/base-layout.astro'

export const prerender = false

// Check if user already has session
const { getAuth } = await import('@/lib/auth')
const auth = getAuth()
const session = await auth.api.getSession({ headers: Astro.request.headers })
if (session?.session) {
  return Astro.redirect('/dashboard')
}

const rawRedirect = Astro.url.searchParams.get('redirect') || '/dashboard'
const redirect = rawRedirect.startsWith('/') && !rawRedirect.startsWith('//') ? rawRedirect : '/dashboard'
const siteUrl = import.meta.env.PUBLIC_SITE_URL || process.env.PUBLIC_SITE_URL || 'http://localhost:4321'
const hasGoogle = !!(import.meta.env.GOOGLE_CLIENT_ID || process.env.GOOGLE_CLIENT_ID)
---

<BaseLayout title="Sign In">
  <div style="max-width: 400px; margin: 6rem auto; text-align: center; padding: 2rem">
    <h1 style="font-size: 1.5rem; font-weight: 700; margin-bottom: 0.5rem">Sign In</h1>
    <p style="color: #64748b; margin-bottom: 2rem">Sign in to create your landing page</p>

    {hasGoogle ? (
      <>
        <button
          id="google-login"
          style="display: inline-flex; align-items: center; gap: 0.75rem; padding: 0.75rem 2rem; border: 1px solid #d1d5db; border-radius: 8px; background: white; cursor: pointer; font-size: 0.95rem; font-weight: 500; transition: background 0.15s"
        >
          <svg width="20" height="20" viewBox="0 0 24 24" aria-hidden="true">
            <path d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92a5.06 5.06 0 0 1-2.2 3.32v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.1z" fill="#4285F4"/>
            <path d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z" fill="#34A853"/>
            <path d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z" fill="#FBBC05"/>
            <path d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z" fill="#EA4335"/>
          </svg>
          Continue with Google
        </button>
        <script is:inline define:vars={{ siteUrl, redirect }}>
          document.getElementById('google-login')?.addEventListener('click', () => {
            // Better Auth handles the entire OAuth flow via its API endpoint
            const callbackURL = encodeURIComponent(redirect)
            window.location.href = `${siteUrl}/api/auth/sign-in/social?provider=google&callbackURL=${callbackURL}`
          })
        </script>
      </>
    ) : (
      <div style="padding: 1.5rem; background: #f8fafc; border-radius: 8px; border: 1px solid #e2e8f0">
        <p style="font-size: 0.9rem; color: #64748b; margin-bottom: 0.5rem; font-weight: 500">Auth Not Configured</p>
        <p style="font-size: 0.8rem; color: #94a3b8">Set GOOGLE_CLIENT_ID, GOOGLE_CLIENT_SECRET, and BETTER_AUTH_SECRET env vars to enable sign-in.</p>
      </div>
    )}

    <p style="margin-top: 2rem; font-size: 0.8rem; color: #94a3b8">
      Free account — no credit card required.
    </p>
  </div>
</BaseLayout>
