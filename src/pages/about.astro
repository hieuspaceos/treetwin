---
/**
 * About/Portfolio page — hero, bio, projects grid, skills, social links
 * Projects pulled from Records collection with recordType: 'project'
 */
import BaseLayout from '@/layouts/base-layout.astro'
import { siteConfig } from '@/config/site-config'
import { getCollection } from 'astro:content'

const { about, author, socialLinks } = siteConfig

const projects = await getCollection('records', (e) =>
  e.data.status === 'published' && e.data.recordType === 'project'
)

const socials = Object.entries(socialLinks).filter(([, url]) => url)
---

<BaseLayout title={`About | ${siteConfig.name}`} description={about.bio || siteConfig.description}>
  {/* Hero */}
  <section class="glass-panel mb-8 rounded-2xl px-8 py-10">
    <div class="flex flex-col items-center gap-6 sm:flex-row sm:items-start">
      {about.avatar && (
        <img
          src={about.avatar}
          alt={author.name || 'Avatar'}
          class="h-24 w-24 rounded-full object-cover ring-4 ring-white/50"
          loading="lazy"
        />
      )}
      <div class={about.avatar ? '' : 'text-center sm:text-left'}>
        <h1 class="mb-1 text-3xl font-bold tracking-tight text-slate-900">
          {author.name || siteConfig.name}
        </h1>
        <p class="text-lg text-slate-500">{siteConfig.description}</p>
        {socials.length > 0 && (
          <div class="mt-3 flex flex-wrap gap-2">
            {socials.map(([platform, url]) => (
              <a
                href={url}
                target="_blank"
                rel="noopener noreferrer"
                class="inline-flex items-center gap-1 rounded-full border border-slate-200 px-3 py-1 text-sm text-slate-500 transition-colors hover:border-slate-400 hover:text-slate-700"
              >
                {platform}
              </a>
            ))}
          </div>
        )}
      </div>
    </div>
  </section>

  {/* Bio */}
  {about.bio && (
    <section class="glass-panel mb-8 rounded-2xl px-8 py-8">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-400">About</h2>
      <div class="prose prose-slate max-w-none whitespace-pre-line text-slate-600">
        {about.bio}
      </div>
    </section>
  )}

  {/* Skills */}
  {about.skills.length > 0 && (
    <section class="glass-panel mb-8 rounded-2xl px-8 py-8">
      <h2 class="mb-4 text-sm font-semibold uppercase tracking-wider text-slate-400">Skills</h2>
      <div class="flex flex-wrap gap-2">
        {about.skills.map((skill) => (
          <span class="glass-tag">{skill}</span>
        ))}
      </div>
    </section>
  )}

  {/* Projects */}
  {projects.length > 0 && (
    <section>
      <h2 class="mb-5 text-sm font-semibold uppercase tracking-wider text-slate-400">Projects</h2>
      <div class="grid gap-5 sm:grid-cols-2">
        {projects.map((project) => (
          <a
            href={`/seeds/${project.id}`}
            class="glass-panel block rounded-2xl px-6 py-5 transition-shadow hover:shadow-lg"
          >
            <h3 class="mb-1 text-lg font-semibold text-slate-900">{project.data.title}</h3>
            <p class="text-sm text-slate-500">{project.data.description}</p>
            {(project.data.tags ?? []).length > 0 && (
              <div class="mt-3 flex flex-wrap gap-1.5">
                {(project.data.tags ?? []).map((tag) => (
                  <span class="glass-tag text-xs">{tag}</span>
                ))}
              </div>
            )}
          </a>
        ))}
      </div>
    </section>
  )}
</BaseLayout>
