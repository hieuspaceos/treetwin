---
/** Marketplace catalog — SSR, shows products from Supabase or local SQLite fallback. */
import BaseLayout from '@/layouts/base-layout.astro'
import { getMarketplaceClient } from '@/lib/supabase/client'
import { listProducts } from '@/lib/supabase/marketplace-queries'

const category = Astro.url.searchParams.get('category') || undefined

let products: any[] = []
try {
  const client = await getMarketplaceClient()
  products = await listProducts(client, category)
} catch {
  // Silently fall back to empty list on error
}

const categories = ['all', 'tool', 'template', 'service', 'plugin']
const activeCategory = category || 'all'

function formatPrice(vnd: number): string {
  return new Intl.NumberFormat('vi-VN').format(vnd) + '₫'
}
---
<BaseLayout title="Marketplace">
  <div style="max-width: 1100px; margin: 0 auto; padding: 2rem 1.5rem">
    <!-- Header -->
    <div style="text-align: center; margin-bottom: 2.5rem">
      <h1 style="font-size: 2rem; font-weight: 700; margin-bottom: 0.5rem">Marketplace</h1>
      <p style="color: #64748b; max-width: 500px; margin: 0 auto">
        Digital products for Vietnamese SMBs — buy once, own forever
      </p>
    </div>

    <!-- AI Intent Search -->
    <div style="max-width: 500px; margin: 0 auto 2rem">
      <div id="intent-search" style="position: relative">
        <input
          id="intent-input"
          type="text"
          placeholder="What do you need? e.g. 'Landing page for my coffee shop'"
          style="width: 100%; padding: 0.75rem 1rem; border: 1px solid #d1d5db; border-radius: 10px; font-size: 0.95rem; box-sizing: border-box; outline: none"
        />
        <div
          id="intent-results"
          style="display: none; position: absolute; top: calc(100% + 4px); left: 0; right: 0; background: white; border: 1px solid #e2e8f0; border-radius: 10px; box-shadow: 0 8px 24px rgba(0,0,0,0.1); z-index: 10; max-height: 300px; overflow-y: auto; padding: 0.5rem"
        ></div>
      </div>
    </div>

    <!-- Category tabs -->
    <div style="display: flex; justify-content: center; gap: 0.5rem; margin-bottom: 2rem; flex-wrap: wrap">
      {categories.map(cat => (
        <a
          href={cat === 'all' ? '/marketplace' : `/marketplace?category=${cat}`}
          style={`padding: 0.4rem 1rem; border-radius: 999px; font-size: 0.85rem; text-decoration: none; font-weight: 500; ${activeCategory === cat ? 'background: #1e293b; color: white' : 'background: #f1f5f9; color: #475569'}`}
        >
          {cat.charAt(0).toUpperCase() + cat.slice(1)}
        </a>
      ))}
    </div>

    <!-- Product grid -->
    {products.length > 0 ? (
      <div style="display: grid; grid-template-columns: repeat(auto-fill, minmax(300px, 1fr)); gap: 1.5rem">
        {products.map((p: any) => (
          <a href={`/marketplace/${p.slug}`} style="text-decoration: none; color: inherit">
            <div class="glass-card" style="overflow: hidden; transition: transform 0.2s; cursor: pointer">
              {p.cover_image && (
                <img src={p.cover_image} alt={p.title} style="width: 100%; height: 180px; object-fit: cover" />
              )}
              <div style="padding: 1.25rem">
                <div style="display: flex; justify-content: space-between; align-items: start; margin-bottom: 0.5rem">
                  <h3 style="font-size: 1.1rem; font-weight: 600; margin: 0">{p.title}</h3>
                  <span style="font-size: 0.75rem; padding: 0.2rem 0.6rem; background: #f1f5f9; border-radius: 999px; color: #475569; white-space: nowrap; margin-left: 0.5rem">
                    {p.category}
                  </span>
                </div>
                <p style="color: #64748b; font-size: 0.85rem; margin-bottom: 1rem; line-height: 1.5">
                  {p.short_description || (p.description ? p.description.slice(0, 100) : '')}
                </p>
                <div style="display: flex; justify-content: space-between; align-items: center">
                  <span style="font-size: 1.1rem; font-weight: 700; color: #1e293b">
                    {formatPrice(p.price_vnd)}
                  </span>
                  {p.price_usd > 0 && (
                    <span style="font-size: 0.8rem; color: #94a3b8">
                      ${(p.price_usd / 100).toFixed(0)}
                    </span>
                  )}
                </div>
              </div>
            </div>
          </a>
        ))}
      </div>
    ) : (
      <div style="text-align: center; padding: 3rem; color: #94a3b8">
        <p>No products found</p>
      </div>
    )}
  </div>
</BaseLayout>

<script>
  const input = document.getElementById('intent-input') as HTMLInputElement | null
  const results = document.getElementById('intent-results') as HTMLDivElement | null
  let timer: ReturnType<typeof setTimeout>

  /** Escape user-controlled or AI-generated strings before inserting into innerHTML. */
  function escapeHtml(s: string): string {
    const d = document.createElement('div')
    d.textContent = s
    return d.innerHTML
  }

  input?.addEventListener('input', (e) => {
    clearTimeout(timer)
    const q = (e.target as HTMLInputElement).value.trim()
    if (q.length < 3) {
      if (results) results.style.display = 'none'
      return
    }
    timer = setTimeout(async () => {
      try {
        const res = await fetch('/api/marketplace/intent', {
          method: 'POST',
          headers: { 'Content-Type': 'application/json' },
          body: JSON.stringify({ query: q }),
        })
        const data = await res.json()
        if (!results) return
        if (data.products?.length) {
          results.innerHTML = data.products
            .map(
              (p: any) => `
              <a href="/marketplace/${encodeURIComponent(p.slug)}" style="display:block;padding:0.75rem;text-decoration:none;color:inherit;border-radius:6px;transition:background 0.15s" onmouseover="this.style.background='#f8fafc'" onmouseout="this.style.background='transparent'">
                <strong style="font-size:0.9rem">${escapeHtml(p.title)}</strong>
                ${p.reason ? `<p style="font-size:0.75rem;color:#64748b;margin:0.25rem 0 0">${escapeHtml(p.reason)}</p>` : ''}
              </a>
            `
            )
            .join('')
          results.style.display = 'block'
        } else {
          results.style.display = 'none'
        }
      } catch {
        // Silently ignore search errors
      }
    }, 500)
  })

  // Close results when clicking outside the search widget
  document.addEventListener('click', (e) => {
    if (!document.getElementById('intent-search')?.contains(e.target as Node)) {
      if (results) results.style.display = 'none'
    }
  })
</script>
