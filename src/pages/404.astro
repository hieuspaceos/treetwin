---
/**
 * 404 page — glass-themed with tree metaphor, Pagefind search, recent articles
 */
import BaseLayout from '@/layouts/base-layout.astro'
import { siteConfig } from '@/config/site-config'
import { getCollection } from 'astro:content'

const articles = (await getCollection('articles', (e) => e.data.status === 'published'))
  .sort((a, b) => {
    const da = a.data.publishedAt ? new Date(a.data.publishedAt).getTime() : 0
    const db = b.data.publishedAt ? new Date(b.data.publishedAt).getTime() : 0
    return db - da
  })
  .slice(0, 3)
---

<BaseLayout title={`Not Found | ${siteConfig.name}`}>
  <div class="flex flex-col items-center gap-8 py-8">
    {/* Big 404 with glass effect */}
    <div class="glass-panel rounded-3xl px-16 py-12 text-center">
      <div class="mb-2 text-8xl font-black tracking-tighter text-slate-200">404</div>
      <div class="mb-1 flex items-center justify-center gap-2 text-slate-600">
        <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-green-500">
          <path d="M12 22V12" /><path d="M12 12L8 8" /><path d="M12 12L16 8" />
          <path d="M12 8L9 5" /><path d="M12 8L15 5" />
          <path d="M12 5L10 3" /><path d="M12 5L14 3" />
        </svg>
        <span class="text-lg font-medium">This seed hasn't sprouted yet</span>
      </div>
      <p class="text-sm text-slate-400">The page you're looking for doesn't exist or has been moved.</p>
    </div>

    {/* Search bar */}
    {siteConfig.features.search && (
      <div class="w-full max-w-md">
        <div id="search-404"></div>
        <link href="/pagefind/pagefind-ui.css" rel="stylesheet" />
        <script is:inline>
          window.addEventListener('DOMContentLoaded', () => {
            if (window.PagefindUI) {
              new window.PagefindUI({
                element: '#search-404',
                showSubResults: false,
                showImages: false,
              })
            }
          })
        </script>
      </div>
    )}

    {/* Recent articles */}
    {articles.length > 0 && (
      <div class="w-full max-w-lg">
        <h2 class="mb-4 text-center text-sm font-semibold uppercase tracking-wider text-slate-400">
          Recent Seeds
        </h2>
        <div class="flex flex-col gap-3">
          {articles.map((article) => (
            <a
              href={`/seeds/${article.id}`}
              class="glass-panel flex items-center gap-3 rounded-xl px-5 py-4 transition-shadow hover:shadow-lg"
            >
              <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
                stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="shrink-0 text-slate-400">
                <path d="M14 2H6a2 2 0 0 0-2 2v16a2 2 0 0 0 2 2h12a2 2 0 0 0 2-2V8z" />
                <polyline points="14 2 14 8 20 8" />
              </svg>
              <div class="min-w-0">
                <div class="truncate font-medium text-slate-700">{article.data.title}</div>
                <div class="truncate text-xs text-slate-400">{article.data.description}</div>
              </div>
            </a>
          ))}
        </div>
      </div>
    )}

    {/* Back to home */}
    <a
      href="/"
      class="inline-flex items-center gap-2 rounded-full border border-slate-200 px-5 py-2.5 text-sm font-medium text-slate-600 transition-colors hover:border-slate-400 hover:text-slate-900"
    >
      <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor"
        stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
        <path d="M19 12H5" />
        <polyline points="12 19 5 12 12 5" />
      </svg>
      Back to Home
    </a>
  </div>
</BaseLayout>
