---
/**
 * Dynamic landing page route — renders YAML-configured landing pages.
 * Each landing page config in src/content/landing-pages/*.yaml becomes a static page.
 * The 'home' slug is excluded (handled by index.astro).
 * Nav and footer are rendered as sections (not from layout) so users can toggle them.
 */
import { getCollection } from 'astro:content'
import LandingLayout from '@/layouts/landing-layout.astro'
import LandingSectionRenderer from '@/components/landing/landing-section-renderer.astro'
import type { LandingSection, LandingDesign } from '@/lib/landing/landing-types'

export async function getStaticPaths() {
  const pages = await getCollection('landingPages')
  const products = await getCollection('products')
  return pages
    .filter(p => p.id !== 'home')
    .map(p => {
      const product = products.find(pr => pr.data.landingPage === p.id)
      return { params: { landing: p.id }, props: { page: p, product: product ?? null } }
    })
}

const { page, product } = Astro.props
const sections = page.data.sections as unknown as LandingSection[]
const design = (page.data as Record<string, unknown>).design as LandingDesign | undefined
// If nav/footer section exists (even disabled), hide layout's nav/footer
// User controls visibility via section enabled toggle — layout never overrides
const hasNav = sections.some(s => s.type === 'nav')
const hasFooter = sections.some(s => s.type === 'footer')
---

<LandingLayout
  title={page.data.title}
  description={page.data.description}
  brandName={hasNav ? undefined : page.data.title}
  ctaText={!hasNav && product ? 'Open Dashboard' : undefined}
  ctaHref={!hasNav && product ? `/${product.data.slug}/admin` : undefined}
  hideNav={hasNav}
  hideFooter={hasFooter}
  design={design}
>
  <LandingSectionRenderer sections={sections} pageTitle={page.data.title} />
</LandingLayout>
