---
export const prerender = false

/**
 * Dynamic landing page route — dual-source renderer.
 * Priority: YAML (owner pages) → Turso DB (SaaS user pages, published only) → 404.
 * Nav and footer are rendered as sections (not from layout) so users can toggle them.
 */
import { getCollection, getEntry } from 'astro:content'
import LandingLayout from '@/layouts/landing-layout.astro'
import LandingSectionRenderer from '@/components/landing/landing-section-renderer.astro'
import type { LandingSection, LandingDesign, LandingSeo } from '@/lib/landing/landing-types'

const { landing } = Astro.params

// --- Source 1: YAML (owner pages — ck2, ck3, etc.) ---
const yamlPage = await getEntry('landingPages', landing!)

let sections: LandingSection[] = []
let title = ''
let description = ''
let design: LandingDesign | undefined
let seo: LandingSeo | undefined
let product: any = null

if (yamlPage) {
  const pageData = yamlPage.data as Record<string, unknown>
  sections = pageData.sections as unknown as LandingSection[]
  title = yamlPage.data.title
  description = yamlPage.data.description || ''
  design = pageData.design as LandingDesign | undefined
  seo = pageData.seo as LandingSeo | undefined

  // Product association (YAML only)
  let products: any[] = []
  try { products = await getCollection('products') } catch {}
  product = products.find((pr: any) => pr.data?.landingPage === landing) ?? null
} else {
  // --- Source 2: Turso DB (SaaS user pages, published only) ---
  const tursoUrl = import.meta.env.TURSO_URL || process.env.TURSO_URL
  if (tursoUrl) {
    try {
      const { getPageBySlug } = await import('@/lib/saas/landing-page-db')
      const dbPage = await getPageBySlug(landing!)
      if (!dbPage) return Astro.redirect('/404')

      // Allow preview for page owner (authenticated + owns the page)
      const isPreview = Astro.url.searchParams.get('preview') === 'true'
      const saasUser = (Astro.locals as Record<string, any>).saasUser
      if (!dbPage.published && !(isPreview && saasUser && dbPage.userId === saasUser.id)) {
        return Astro.redirect('/404')
      }

      const config = JSON.parse(dbPage.config)
      sections = config.sections || []
      title = config.title || dbPage.name
      description = config.description || ''
      design = config.design
      seo = config.seo
    } catch {
      return Astro.redirect('/404')
    }
  } else {
    return Astro.redirect('/404')
  }
}

if (sections.length === 0) return Astro.redirect('/404')

const hasNav = sections.some(s => s.type === 'nav')
const hasFooter = sections.some(s => s.type === 'footer')
---

<LandingLayout
  title={title}
  description={description}
  brandName={hasNav ? undefined : title}
  ctaText={!hasNav && product ? 'Open Dashboard' : undefined}
  ctaHref={!hasNav && product ? `/${product.data.slug}/admin` : undefined}
  hideNav={hasNav}
  hideFooter={hasFooter}
  design={design}
>
  {seo?.ogImage && <meta slot="head" property="og:image" content={seo.ogImage} />}
  {seo?.keywords && <meta slot="head" name="keywords" content={seo.keywords} />}
  {seo?.noindex && <meta slot="head" name="robots" content="noindex, nofollow" />}
  {seo?.canonicalUrl && <link slot="head" rel="canonical" href={seo.canonicalUrl} />}
  <LandingSectionRenderer sections={sections} pageTitle={title} />
</LandingLayout>
