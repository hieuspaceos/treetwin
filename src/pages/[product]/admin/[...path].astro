---
/**
 * Product admin SPA host page — renders product-scoped React admin island.
 * Mirrors src/pages/admin/[...path].astro but loads product config from content collection.
 * All sub-routing handled client-side by wouter via AdminApp.
 */
export const prerender = false

import { getCollection } from 'astro:content'
import { siteConfig } from '@/config/site-config'
import { getTheme, themeToStyleVars } from '@/themes/theme-resolver'
import AdminApp from '@/components/admin/admin-app'
import '@/styles/globals.css'
import '@/styles/admin.css'

const RESERVED_SLUGS = ['admin', 'api', 'search', 'about', 'keystatic', 'og', 'seeds']

const { product: productSlug } = Astro.params

// Guard reserved slugs — these are handled by more-specific Astro routes
if (!productSlug || RESERVED_SLUGS.includes(productSlug)) {
  return Astro.redirect('/404')
}

// Load product config from content collection
const products = await getCollection('products')
const product = products.find(p => p.data.slug === productSlug)

if (!product) {
  return Astro.redirect('/404')
}

// Serialize product config as plain data — no functions, safe for client prop
const productConfig = {
  slug: product.data.slug,
  name: product.data.name,
  description: product.data.description,
  landingPage: product.data.landingPage,
  icon: product.data.icon,
  features: product.data.features,
  coreCollections: product.data.coreCollections,
  sidebarSections: product.data.sidebarSections,
}

const theme = getTheme(siteConfig.theme.id)
const themeVars = themeToStyleVars(theme)
---

<html lang="en">
<head>
  <meta charset="utf-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <meta name="robots" content="noindex, nofollow" />
  <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  <title>{product.data.name} | {siteConfig.name}</title>
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
  <link href="https://fonts.googleapis.com/css2?family=Fira+Code:wght@400;500;600&family=Fira+Sans:wght@400;500;600;700&display=swap" rel="stylesheet" />
</head>
<body style={themeVars}>
  <!-- Static loading placeholder — visible until React hydrates and removes it -->
  <div id="admin-loader" class="admin-loading">
    <div class="admin-loading-spinner"></div>
    Loading...
  </div>
  <AdminApp
    client:only="react"
    siteName={siteConfig.name}
    productConfig={productConfig}
  />
</body>
</html>
