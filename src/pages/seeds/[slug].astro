---
import { getCollection, render } from 'astro:content'
import BaseLayout from '@/layouts/base-layout.astro'
import Breadcrumb from '@/components/breadcrumb.astro'
import { Toc } from '@/components/islands/toc'
import { articleJsonLd, breadcrumbJsonLd, safeJsonLd } from '@/lib/seo/json-ld'
import { siteConfig } from '@/config/site-config'
import SubscribeForm from '@/components/subscribe-form.astro'

export async function getStaticPaths() {
  const articles = await getCollection('articles', (e) => e.data.status === 'published')
  const notes = await getCollection('notes', (e) => e.data.status === 'published')

  const articlePaths = articles.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, collection: 'articles' as const },
  }))
  const notePaths = notes.map((entry) => ({
    params: { slug: entry.id },
    props: { entry, collection: 'notes' as const },
  }))

  return [...articlePaths, ...notePaths]
}

const { entry, collection } = Astro.props
const isArticle = collection === 'articles'

// Render Markdoc content and extract headings for articles
let Content: any = null
let headings: { depth: number; slug: string; text: string }[] = []
if (isArticle) {
  const rendered = await render(entry)
  Content = rendered.Content
  headings = rendered.headings
}

// Map Astro headings to Toc island format
const tocHeadings = headings.map((h) => ({
  id: h.slug,
  text: h.text,
  level: h.depth,
}))

const date = entry.data.publishedAt
  ? new Date(entry.data.publishedAt).toLocaleDateString('en-US', {
      year: 'numeric',
      month: 'long',
      day: 'numeric',
    })
  : null

const pageTitle = `${entry.data.seo?.seoTitle || entry.data.title} | ${siteConfig.name}`
const ogImageUrl =
  entry.data.seo?.ogImage ||
  `${siteConfig.url}/og?title=${encodeURIComponent(entry.data.title.slice(0, 100))}&desc=${encodeURIComponent(entry.data.description.slice(0, 200))}`
---

<BaseLayout title={pageTitle} description={entry.data.description}>
  <Fragment slot="head">
    <script
      is:inline
      type="application/ld+json"
      set:html={safeJsonLd(
        articleJsonLd({
          title: entry.data.title,
          description: entry.data.description,
          summary: entry.data.summary,
          slug: entry.id,
          publishedAt: entry.data.publishedAt,
          image: ogImageUrl,
          keywords: entry.data.tags,
          category: entry.data.category,
        }),
      )}
    />
    <script
      is:inline
      type="application/ld+json"
      set:html={safeJsonLd(
        breadcrumbJsonLd([
          { name: 'Home', url: siteConfig.url },
          { name: isArticle ? 'Articles' : 'Notes', url: `${siteConfig.url}/seeds` },
          { name: entry.data.title },
        ]),
      )}
    />
    <meta property="og:title" content={entry.data.seo?.seoTitle || entry.data.title} />
    <meta property="og:description" content={entry.data.description} />
    <meta property="og:type" content="article" />
    <meta property="og:url" content={`${siteConfig.url}/seeds/${entry.id}`} />
    <meta property="og:image" content={ogImageUrl} />
    {entry.data.publishedAt && (
      <meta property="article:published_time" content={entry.data.publishedAt} />
    )}
    <meta name="twitter:card" content="summary_large_image" />
    {entry.data.seo?.noindex && <meta name="robots" content="noindex, nofollow" />}
    {entry.data.publishedAt && <meta name="DC.date" content={entry.data.publishedAt} />}
    <meta name="citation_title" content={entry.data.title} />
    <meta name="citation_url" content={`${siteConfig.url}/seeds/${entry.id}`} />
    {siteConfig.author.name && <meta name="citation_author" content={siteConfig.author.name} />}
    {entry.data.publishedAt && <meta name="citation_publication_date" content={entry.data.publishedAt} />}
  </Fragment>

  <article data-pagefind-body>
    <Breadcrumb
      items={[
        { label: 'Home', href: '/' },
        { label: isArticle ? 'Articles' : 'Notes' },
        { label: entry.data.title },
      ]}
    />

    <!-- Header card -->
    <header class="glass-panel mb-10 rounded-2xl px-8 py-8">
      <h1 class="mb-3 text-3xl font-bold tracking-tight text-slate-900">
        {entry.data.title}
      </h1>
      <p class="mb-4 text-lg leading-relaxed text-slate-500">
        {entry.data.description}
      </p>
      <div class="flex items-center gap-3 text-sm">
        <span
          class:list={[
            'inline-flex items-center gap-1 rounded-full px-2.5 py-0.5 font-medium',
            isArticle
              ? 'border border-blue-500/12 bg-blue-500/8 text-blue-600'
              : 'border border-green-500/12 bg-green-500/8 text-green-600',
          ]}
        >
          <span class="capitalize">{collection}</span>
        </span>
        {date && (
          <time datetime={entry.data.publishedAt!} class="text-slate-400">{date}</time>
        )}
      </div>
      {(entry.data.tags ?? []).length > 0 && (
        <div class="mt-4 flex flex-wrap gap-1.5">
          {(entry.data.tags ?? []).map((tag) => (
            <span class="glass-tag">{tag}</span>
          ))}
        </div>
      )}
    </header>

    <!-- Content + optional ToC sidebar -->
    <div class={tocHeadings.length > 0 ? 'lg:grid lg:grid-cols-[1fr_240px] lg:gap-10' : ''}>
      <div>
        {isArticle && Content ? (
          <div class="prose prose-slate max-w-none">
            <Content />
          </div>
        ) : (
          <div class="prose prose-slate max-w-none whitespace-pre-wrap">
            {(entry.data as any).content || ''}
          </div>
        )}
      </div>

      {tocHeadings.length > 0 && (
        <aside class="hidden lg:block">
          <div class="sticky top-24">
            <Toc client:load headings={tocHeadings} />
          </div>
        </aside>
      )}
    </div>
  </article>

  <div class="mt-10">
    <SubscribeForm />
  </div>
</BaseLayout>
