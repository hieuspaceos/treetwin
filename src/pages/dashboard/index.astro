---
/**
 * SaaS user dashboard — shows user's landing pages.
 * Protected by Better Auth session. Redirects to /auth/login if not authenticated.
 */
import BaseLayout from '@/layouts/base-layout.astro'
import { getAuth } from '@/lib/auth'
import { getDb } from '@/db/client'
import { landingPages } from '@/db/schema'
import { eq } from 'drizzle-orm'

export const prerender = false

const auth = getAuth()
const session = await auth.api.getSession({ headers: Astro.request.headers })

if (!session?.session) {
  return Astro.redirect('/auth/login?redirect=/dashboard')
}

const user = session.user
const db = getDb()

// Fetch user's landing pages from Turso
let pages: { slug: string; name: string; updatedAt: string | null }[] = []
try {
  pages = await db
    .select({ slug: landingPages.slug, name: landingPages.name, updatedAt: landingPages.updatedAt })
    .from(landingPages)
    .where(eq(landingPages.userId, user.id))
} catch {
  // DB not configured — show empty state
}
---

<BaseLayout title="Dashboard">
  <div style="max-width: 900px; margin: 0 auto; padding: 2rem 1.5rem">
    <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 2rem">
      <div>
        <h1 style="font-size: 1.75rem; font-weight: 700; margin-bottom: 0.25rem">Dashboard</h1>
        <p style="color: #64748b; font-size: 0.9rem">
          Welcome, {user.name || user.email}
        </p>
      </div>
      <a
        href="/api/auth/sign-out"
        style="padding: 0.4rem 1rem; border: 1px solid #d1d5db; border-radius: 6px; font-size: 0.8rem; color: #64748b; text-decoration: none"
      >
        Sign Out
      </a>
    </div>

    <!-- Landing Pages -->
    <section>
      <div style="display: flex; justify-content: space-between; align-items: center; margin-bottom: 1rem">
        <h2 style="font-size: 1.2rem; font-weight: 600">Your Landing Pages</h2>
        <a
          href="/dashboard/new"
          style="padding: 0.5rem 1.25rem; background: #10b981; color: white; border-radius: 6px; font-size: 0.85rem; font-weight: 600; text-decoration: none"
        >
          + New Page
        </a>
      </div>

      {pages.length > 0 ? (
        <div style="display: flex; flex-direction: column; gap: 0.75rem">
          {pages.map((page) => (
            <div style="background: #f8fafc; border: 1px solid #e2e8f0; border-radius: 10px; padding: 1.25rem; display: flex; justify-content: space-between; align-items: center; gap: 1rem; flex-wrap: wrap">
              <div>
                <p style="font-size: 1rem; font-weight: 600; margin: 0 0 0.25rem">{page.name || page.slug}</p>
                <p style="font-size: 0.8rem; color: #64748b; margin: 0">
                  /{page.slug}
                  {page.updatedAt ? ` · Updated ${new Date(page.updatedAt).toLocaleDateString()}` : ''}
                </p>
              </div>
              <div style="display: flex; gap: 0.5rem">
                <a
                  href={`/${page.slug}`}
                  target="_blank"
                  style="padding: 0.35rem 0.75rem; border: 1px solid #d1d5db; border-radius: 6px; font-size: 0.8rem; color: #475569; text-decoration: none"
                >
                  View
                </a>
                <a
                  href={`/dashboard/edit/${page.slug}`}
                  style="padding: 0.35rem 0.75rem; background: #1e293b; color: white; border-radius: 6px; font-size: 0.8rem; text-decoration: none"
                >
                  Edit
                </a>
              </div>
            </div>
          ))}
        </div>
      ) : (
        <div style="text-align: center; padding: 3rem; color: #94a3b8; border: 2px dashed #d1d5db; border-radius: 10px">
          <p style="margin: 0 0 0.5rem; font-size: 1.1rem; font-weight: 500">No landing pages yet</p>
          <p style="margin: 0 0 1.5rem; font-size: 0.85rem">Create your first landing page — describe your product and we'll handle the rest.</p>
          <a
            href="/dashboard/new"
            style="padding: 0.6rem 1.5rem; background: #10b981; color: white; border-radius: 8px; font-size: 0.9rem; font-weight: 600; text-decoration: none"
          >
            Create Your First Page
          </a>
        </div>
      )}
    </section>
  </div>
</BaseLayout>
