---
import BaseLayout from '@/layouts/base-layout.astro'
import SeedCard from '@/components/seed-card.astro'
import { siteConfig } from '@/config/site-config'
import { getAllPublishedSeeds } from '@/lib/content-helpers'
import { websiteJsonLd, safeJsonLd } from '@/lib/seo/json-ld'

const seeds = await getAllPublishedSeeds()
---

<BaseLayout>
  <Fragment slot="head">
    <script is:inline type="application/ld+json" set:html={safeJsonLd(websiteJsonLd())} />
  </Fragment>

  <!-- Hero section -->
  <section class="glass-panel mb-10 rounded-2xl px-8 py-10">
    <div class="flex items-start gap-4">
      <div class="hidden shrink-0 rounded-2xl bg-green-500/10 p-3 sm:block">
        <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor"
          stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round" class="text-green-600">
          <path d="M12 22V12" /><path d="M12 12L8 8" /><path d="M12 12L16 8" />
          <path d="M12 8L9 5" /><path d="M12 8L15 5" />
          <path d="M12 5L10 3" /><path d="M12 5L14 3" />
        </svg>
      </div>
      <div>
        <h1 class="mb-2 text-3xl font-bold tracking-tight text-slate-900">
          {siteConfig.name}
        </h1>
        <p class="text-lg leading-relaxed text-slate-500">
          {siteConfig.description}
        </p>
      </div>
    </div>
  </section>

  <!-- Seeds grid -->
  {seeds.length === 0 ? (
    <div class="glass-panel rounded-2xl px-8 py-12 text-center">
      <p class="text-slate-400">
        No published seeds yet. Create one in{' '}
        <a href="/keystatic" class="text-blue-500 hover:underline">/keystatic</a>.
      </p>
    </div>
  ) : (
    <section>
      <h2 class="mb-5 text-sm font-semibold uppercase tracking-wider text-slate-400">
        Recent Seeds
      </h2>
      <div class="grid gap-5 sm:grid-cols-2">
        {seeds.map((seed) => (
          <SeedCard
            title={seed.data.title}
            description={seed.data.description}
            slug={seed.id}
            publishedAt={seed.data.publishedAt ?? null}
            tags={seed.data.tags ?? []}
            collection={seed.collection}
          />
        ))}
      </div>
    </section>
  )}
</BaseLayout>
