---
export const prerender = true

/**
 * Homepage — renders the 'home' landing page from content/landing-pages/home.yaml.
 * Uses the same landing renderer pipeline as [landing].astro.
 */
import { getCollection } from 'astro:content'
import LandingLayout from '@/layouts/landing-layout.astro'
import LandingSectionRenderer from '@/components/landing/landing-section-renderer.astro'
import type { LandingSection, LandingDesign, LandingSeo } from '@/lib/landing/landing-types'
import { websiteJsonLd, safeJsonLd } from '@/lib/seo/json-ld'

const pages = await getCollection('landingPages')
const page = pages.find(p => p.id === 'home')

if (!page) {
  return Astro.redirect('/404')
}

const { data } = page
const sections = (data.sections || []) as LandingSection[]
const design = (data.design || {}) as LandingDesign
const seo = (data.seo || {}) as LandingSeo
const title = data.title || 'Home'
const description = data.description || ''

const hasNav = sections.some(s => s.type === 'nav')
const hasFooter = sections.some(s => s.type === 'footer')
---

<LandingLayout title={title} description={description} design={design} seo={seo} hideNav={hasNav} hideFooter={hasFooter}>
  <Fragment slot="head">
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link href="https://fonts.googleapis.com/css2?family=DM+Serif+Display:ital@0;1&family=DM+Sans:opsz,wght@9..40,300;9..40,400;9..40,500&display=swap" rel="stylesheet" />
    <script type="application/ld+json" set:html={safeJsonLd(websiteJsonLd())} />
  </Fragment>
  <LandingSectionRenderer sections={sections} pageTitle={title} />
</LandingLayout>
